---
import BaseLayout from '../layouts/BaseLayout.astro';
const WEB3FORMS_KEY = "0e3dc34d-3dac-44e4-b2fb-5f05f45dddf9";
---

<BaseLayout title="The Circle — OUTLYR" activeNav="circle">

<header class="page-header">
  <div class="page-header-inner">
    <p class="tag">// Application</p>
    <h1 class="page-title">The<br><em>Circle.</em></h1>
    <p class="page-sub">
      This is not a form. It is a conversation.<br><br>
      The Circle is a private, reviewed community. We do not select based on what you have achieved, where you studied, or how many people follow you. We select based on one thing — <em>quality of mind and direction of movement.</em><br><br>
      Answer honestly. There are no right answers, but there are real ones. If you find yourself writing what sounds good rather than what is true — stop, and start again. Take your time.
    </p>
  </div>
</header>

<section class="form-section" style="border-top: none;">
  <div class="form-layout">

    <aside class="form-context">
      <div class="context-block">
        <p class="context-label">What we look for</p>
        <ul class="context-list">
          <li>Quality of thinking over credentials</li>
          <li>Direction of movement, not current status</li>
          <li>Bias toward contributing, not just observing</li>
          <li>Honesty about where you actually are</li>
        </ul>
      </div>
      <div class="context-block">
        <p class="context-label">What happens next</p>
        <ul class="context-list">
          <li>Accepted members receive a private invite</li>
        </ul>
      </div>
      <p class="context-note">
        The room is only as good as the people in it.<br>
        Standards are not negotiable.
      </p>
    </aside>

    <div class="form-wrapper">
      <form id="circle-form">
        <input type="hidden" name="access_key" value={WEB3FORMS_KEY} />
        <input type="hidden" name="subject" value="New Circle Application — OUTLYR" />
        <input type="hidden" name="redirect" value="false" />
        <input type="checkbox" name="botcheck" style="display:none" />

        <!-- 01 Name -->
        <div class="field-group">
          <label class="field-label" for="name">
            <span class="label-line"><span class="field-num">01</span> Name <span class="req">*</span></span>
          </label>
          <input class="field-input" type="text" id="name" name="name"
            placeholder="Your full name" required />
        </div>

        <!-- 02 City -->
        <div class="field-group">
          <label class="field-label" for="city">
            <span class="label-line"><span class="field-num">02</span> City <span class="req">*</span></span>
          </label>
          <input class="field-input" type="text" id="city" name="city"
            placeholder="Where you're based" required />
        </div>

        <!-- 03 Age -->
        <div class="field-group">
          <label class="field-label" for="age">
            <span class="label-line"><span class="field-num">03</span> Age <span class="req">*</span></span>
          </label>
          <input class="field-input" type="number" id="age" name="age"
            placeholder="Your age" required />
        </div>

        <!-- 04 What you do -->
        <div class="field-group">
          <label class="field-label" for="occupation">
            <span class="label-line"><span class="field-num">04</span> What do you do? <span class="req">*</span></span>
          </label>
          <input class="field-input" type="text" id="occupation" name="occupation"
            placeholder="Student, founder, engineer, artist, athlete..." required />
        </div>

        <!-- 05 How did you find Outlyr -->
        <div class="field-group">
          <label class="field-label">
            <span class="label-line"><span class="field-num">05</span> How did you find Outlyr? <span class="req">*</span></span>
          </label>
          <div class="radio-group">
            <label class="radio-label">
              <input type="radio" name="source" value="Instagram" />
              <span>Instagram</span>
            </label>
            <label class="radio-label">
              <input type="radio" name="source" value="Word of mouth" />
              <span>Word of mouth</span>
            </label>
            <label class="radio-label">
              <input type="radio" name="source" value="Other" />
              <span>Other</span>
            </label>
          </div>
        </div>

        <!-- 06 Instagram handle -->
        <div class="field-group">
          <label class="field-label" for="instagram">
            <span class="label-line"><span class="field-num">06</span> Instagram Handle</span>
            <span class="field-hint">Optional — only if you'd like to share.</span>
          </label>
          <input class="field-input" type="text" id="instagram" name="instagram"
            placeholder="@yourhandle" />
        </div>

        <!-- 07 What are you building -->
        <div class="field-group">
          <label class="field-label" for="building">
            <span class="label-line"><span class="field-num">07</span> What are you building or pursuing right now — that most people around you don't know about or wouldn't understand? <span class="req">*</span></span>
          </label>
          <textarea class="field-textarea" id="building" name="building"
            placeholder="Be specific. Vague answers tell us nothing."
            rows="5" required></textarea>
        </div>

        <!-- 08 What you wish someone told you -->
        <div class="field-group">
          <label class="field-label" for="lesson">
            <span class="label-line"><span class="field-num">08</span> What do you know now that you wish someone had told you three years ago — and why do you think nobody did? <span class="req">*</span></span>
          </label>
          <textarea class="field-textarea" id="lesson" name="lesson"
            placeholder="Take your time with this one."
            rows="5" required></textarea>
        </div>

        <!-- 09 Who you're afraid of becoming -->
        <div class="field-group">
          <label class="field-label" for="fear">
            <span class="label-line"><span class="field-num">09</span> What kind of person are you most afraid of turning into — and what are you actively doing to make sure you don't? <span class="req">*</span></span>
          </label>
          <textarea class="field-textarea" id="fear" name="fear"
            placeholder="Honest answers only."
            rows="5" required></textarea>
        </div>

        <!-- 10 What you'd bring -->
        <div class="field-group">
          <label class="field-label" for="bring">
            <span class="label-line"><span class="field-num">10</span> What would you bring to a room of people who are all already working on something? <span class="req">*</span></span>
          </label>
          <textarea class="field-textarea" id="bring" name="bring"
            placeholder="Not what you've done — what you bring."
            rows="4" required></textarea>
        </div>

        <!-- 11 Email -->
        <div class="field-group">
          <label class="field-label" for="email">
            <span class="label-line"><span class="field-num">11</span> Email <span class="req">*</span></span>
          </label>
          <input class="field-input" type="email" id="email" name="email"
            placeholder="your@email.com" required />
        </div>

        <!-- 12 WhatsApp -->
        <div class="field-group">
          <label class="field-label" for="whatsapp">
            <span class="label-line"><span class="field-num">12</span> How do we reach you when you're selected? <span class="req">*</span></span>
            <span class="field-hint">WhatsApp number — include country code e.g. +91 98765 43210</span>
          </label>
          <input class="field-input" type="tel" id="whatsapp" name="whatsapp"
            placeholder="+91" required />
          <p class="field-disclaimer">Your number will only be used to notify you of your selection. Nothing else.</p>
        </div>

        <div class="form-footer">
          <p class="req-note"><span class="req">*</span> Required field</p>
          <button type="submit" class="submit-btn" id="submit-btn">
            <span id="btn-text">Submit Application</span>
            <span id="btn-arrow">↗</span>
          </button>
          <p class="form-disclaimer">
            No newsletters. No data sold. Your application is read by a human.
          </p>
        </div>
      </form>

      <div class="success-state" id="success-state">
        <p class="success-check">✓</p>
        <h2 class="success-title">Application Received.</h2>
        <p class="success-body">
          We'll review it within 7 days.<br>
          If you're in, you'll hear from us on WhatsApp with a private invite.<br>
          If not — no hard feelings. Keep building.
        </p>
        <a href="/" class="success-link">← Back to Outlyr</a>
      </div>
    </div>

  </div>
</section>

</BaseLayout>

<style>
  /* ── PAGE HEADER ── */
  .page-header {
    padding: 180px 56px 80px;
    border-bottom: 1px solid var(--a10);
  }
  .page-header-inner { max-width: 760px; }

  .page-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(72px, 12vw, 160px);
    line-height: 0.86; letter-spacing: 0.01em;
    margin-top: 28px; margin-bottom: 40px;
  }
  .page-title em { color: var(--acc); font-style: italic; }

  .page-sub {
    font-size: clamp(18px, 1.8vw, 22px);
    line-height: 1.85; font-style: italic; color: var(--t55);
    max-width: 640px;
  }
  .page-sub em { color: var(--tx); font-style: italic; }

  /* ── LAYOUT ── */
  .form-section { padding: 80px 56px 120px; }

  .form-layout {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 80px; align-items: start;
  }

  /* ── CONTEXT ASIDE ── */
  .form-context {
    position: sticky; top: 100px;
    display: flex; flex-direction: column; gap: 48px;
  }
  .context-label {
    font-family: 'DM Mono', monospace;
    font-size: 9px; letter-spacing: 0.32em; text-transform: uppercase;
    color: var(--acc); margin-bottom: 20px;
  }
  .context-list {
    list-style: none; display: flex; flex-direction: column; gap: 14px;
  }
  .context-list li {
    font-size: clamp(15px, 1.3vw, 18px);
    line-height: 1.7; font-style: italic; color: var(--t30);
    padding-left: 18px; position: relative;
  }
  .context-list li::before {
    content: '—'; position: absolute; left: 0;
    color: var(--a40); font-style: normal;
  }
  .context-note {
    font-family: 'DM Mono', monospace;
    font-size: 9px; letter-spacing: 0.16em; line-height: 1.9;
    text-transform: uppercase; color: var(--t30);
    border-left: 1px solid var(--a20); padding-left: 16px;
  }

  /* ── FORM ── */
  #circle-form {
    display: flex; flex-direction: column; gap: 56px;
  }
  .field-group {
    display: flex; flex-direction: column; gap: 12px;
  }
  .field-label {
    display: flex; flex-direction: column; gap: 8px;
    font-family: 'DM Mono', monospace;
    font-size: 12px; letter-spacing: 0.26em; text-transform: uppercase;
    color: var(--t55); line-height: 1.7;
  }
  .label-line {
    display: block;
  }
  .field-num { color: var(--acc); margin-right: 10px; }
  .req { color: var(--acc); margin-left: 4px; }
  .req-note {
    font-family: 'DM Mono', monospace;
    font-size: 9px; letter-spacing: 0.2em;
    text-transform: uppercase; color: var(--t30);
    margin-bottom: 8px;
  }
  .field-hint {
    font-family: 'DM Mono', monospace;  
    font-size: 9px; letter-spacing: 0.16em;
    color: var(--t30); text-transform: none; margin-top: 2px;
  }
  .field-disclaimer {
    font-family: 'DM Mono', monospace;
    font-size: 9px; letter-spacing: 0.14em;
    color: var(--t30); text-transform: uppercase;
    margin-top: 8px; line-height: 1.7;
    border-left: 1px solid var(--a20); padding-left: 12px;
  }

  .field-input,
  .field-textarea {
    background: transparent; border: none;
    border-bottom: 1px solid var(--a20);
    padding: 14px 0; width: 100%;
    color: var(--tx);
    font-family: 'DM Mono', monospace;
    font-size: clamp(14px, 1.2vw, 16px);
    font-weight: 300; font-style: normal;
    outline: none; transition: border-color 0.3s;
    caret-color: var(--acc);
  }
  .field-input::placeholder,
  .field-textarea::placeholder { color: var(--t30); font-style: italic; }
  .field-input:focus,
  .field-textarea:focus { border-bottom-color: var(--acc); }
  .field-textarea { resize: none; line-height: 1.75; }

  input[type=number]::-webkit-inner-spin-button,
  input[type=number]::-webkit-outer-spin-button { -webkit-appearance: none; }
  input[type=number] { -moz-appearance: textfield; }

  /* ── RADIO GROUP ── */
  .radio-group {
    display: flex; gap: 32px; flex-wrap: wrap;
    padding: 8px 0;
  }
  .radio-label {
    display: flex; align-items: center; gap: 12px;
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(20px, 2vw, 26px);
    font-style: italic; color: var(--t55);
    cursor: crosshair; transition: color 0.3s;
  }
  .radio-label:hover { color: var(--tx); }
  .radio-label input[type="radio"] {
    appearance: none; -webkit-appearance: none;
    width: 14px; height: 14px;
    border: 1px solid var(--a40); border-radius: 50%;
    flex-shrink: 0;
    transition: border-color 0.3s, background 0.3s;
    cursor: crosshair;
  }
  .radio-label input[type="radio"]:checked {
    border-color: var(--acc);
    background: var(--acc);
  }
  .radio-label input[type="radio"]:checked + span { color: var(--tx); }

  /* ── VALIDATION ── */
  .field-error {
    border-bottom-color: rgba(220, 80, 80, 0.6) !important;
  }
  .error-msg {
    font-family: 'DM Mono', monospace;
    font-size: 9px; letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(220, 80, 80, 0.8);
    margin-top: 8px; display: block;
  }

  /* ── SUBMIT ── */
  .form-footer {
    display: flex; flex-direction: column;
    align-items: flex-start; gap: 20px;
    padding-top: 24px; border-top: 1px solid var(--a10);
    margin-top: 16px;
  }
  .submit-btn {
    display: inline-flex; align-items: center; gap: 14px;
    background: var(--acc); color: var(--bg);
    border: 1px solid var(--acc); padding: 18px 48px;
    font-family: 'DM Mono', monospace;
    font-size: 9px; letter-spacing: 0.32em; text-transform: uppercase;
    transition: background 0.3s, color 0.3s;
  }
  .submit-btn:hover { background: transparent; color: var(--acc); }
  .submit-btn:disabled { opacity: 0.5; pointer-events: none; }
  #btn-arrow { font-size: 14px; transition: transform 0.3s; }
  .submit-btn:hover #btn-arrow { transform: translate(3px, -3px); }
  .form-disclaimer {
    font-family: 'DM Mono', monospace;
    font-size: 9px; letter-spacing: 0.16em;
    text-transform: uppercase; color: var(--t30); line-height: 1.8;
  }

  /* ── SUCCESS ── */
  .success-state { display: none; padding: 80px 0; }
  .success-state.visible { display: block; }
  .success-check {
    font-family: 'DM Mono', monospace;
    font-size: 11px; letter-spacing: 0.3em;
    color: var(--acc); margin-bottom: 28px;
  }
  .success-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(48px, 6vw, 80px);
    line-height: 0.9; margin-bottom: 32px;
  }
  .success-body {
    font-size: clamp(20px, 2vw, 26px);
    line-height: 1.85; font-style: italic;
    color: var(--t55); margin-bottom: 40px;
  }
  .success-link {
    font-family: 'DM Mono', monospace;
    font-size: 9px; letter-spacing: 0.28em; text-transform: uppercase;
    color: var(--acc); text-decoration: none;
    border-bottom: 1px solid var(--a20); padding-bottom: 4px;
    transition: border-color 0.3s;
  }
  .success-link:hover { border-color: var(--acc); }

  /* ── MOBILE ── */
  @media (max-width: 960px) {
    .page-header { padding: 140px 24px 60px; }
    .form-section { padding: 56px 24px 80px; }
    .form-layout { grid-template-columns: 1fr; gap: 48px; }
    .form-context { position: static; }
    .radio-group { gap: 20px; }
  }
</style>

<script is:inline>
  const form = document.getElementById('circle-form');
  const successState = document.getElementById('success-state');
  const submitBtn = document.getElementById('submit-btn');
  const btnText = document.getElementById('btn-text');

  function showError(field, message) {
    clearError(field);
    field.classList.add('field-error');
    const err = document.createElement('span');
    err.className = 'error-msg';
    err.textContent = message;
    field.parentNode.appendChild(err);
  }

  function clearError(field) {
    field.classList.remove('field-error');
    const existing = field.parentNode.querySelector('.error-msg');
    if (existing) existing.remove();
  }

  form.querySelectorAll('.field-input, .field-textarea').forEach(function(field) {
    field.addEventListener('input', function() { clearError(this); });
  });

  form.querySelectorAll('input[type="radio"]').forEach(function(radio) {
    radio.addEventListener('change', function() {
      const existing = form.querySelector('.radio-group').parentNode.querySelector('.error-msg');
      if (existing) existing.remove();
    });
  });

  function validateForm() {
    let valid = true;
    let firstError = null;

    form.querySelectorAll('.field-input[required]').forEach(function(field) {
      if (!field.value.trim()) {
        showError(field, 'This field is required');
        if (!firstError) firstError = field;
        valid = false;
      } else if (field.type === 'email' && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(field.value)) {
        showError(field, 'Please enter a valid email address');
        if (!firstError) firstError = field;
        valid = false;
      } else if (field.type === 'tel' && field.value.trim().length < 7) {
        showError(field, 'Please enter a valid phone number');
        if (!firstError) firstError = field;
        valid = false;
      } else if (field.type === 'number') {
        const val = parseInt(field.value);
        if (isNaN(val) || val < 16 || val > 99) {
          showError(field, 'Please enter a valid age');
          if (!firstError) firstError = field;
          valid = false;
        }
      } else {
        clearError(field);
      }
    });

    form.querySelectorAll('.field-textarea[required]').forEach(function(field) {
      if (!field.value.trim()) {
        showError(field, 'This field is required');
        if (!firstError) firstError = field;
        valid = false;
      } else {
        clearError(field);
      }
    });

    const radioChecked = form.querySelector('input[name="source"]:checked');
    if (!radioChecked) {
      const radioGroup = form.querySelector('.radio-group');
      const existing = radioGroup.parentNode.querySelector('.error-msg');
      if (existing) existing.remove();
      const err = document.createElement('span');
      err.className = 'error-msg';
      err.textContent = 'Please select one option';
      radioGroup.parentNode.appendChild(err);
      if (!firstError) firstError = radioGroup;
      valid = false;
    }

    if (firstError) {
      firstError.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }

    return valid;
  }

  form.addEventListener('submit', async function(e) {
    e.preventDefault();
    if (!validateForm()) return;

    submitBtn.disabled = true;
    btnText.textContent = 'Submitting...';

    try {
      const res = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(Object.fromEntries(new FormData(form))),
      });
      const json = await res.json();
      if (json.success) {
        form.style.display = 'none';
        successState.classList.add('visible');
        window.scrollTo({ top: 0, behavior: 'smooth' });
      } else {
        btnText.textContent = 'Something went wrong — try again';
        submitBtn.disabled = false;
      }
    } catch {
      btnText.textContent = 'Network error — try again';
      submitBtn.disabled = false;
    }
  });
</script>