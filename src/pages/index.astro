---
import BaseHead from '../components/BaseHead.astro';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>OUTLYR — Built Not Born</title>
  <meta name="description" content="A community of deliberate builders. Not for everyone." />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --black: #0a0a08;
      --off-white: #f0ede6;
      --warm-white: #f7f4ed;
      --gold: #c8a96e;
      --gold-dim: #8a6e3e;
      --muted: #3a3830;
      --grain-opacity: 0.045;
    }

    html { scroll-behavior: smooth; }

    body {
      background-color: var(--black);
      color: var(--off-white);
      font-family: 'Cormorant Garamond', serif;
      overflow-x: hidden;
      cursor: crosshair;
    }

    body::before {
      content: '';
      position: fixed; inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='1'/%3E%3C/svg%3E");
      opacity: var(--grain-opacity);
      pointer-events: none;
      z-index: 9999;
    }

    /* ── NAV ── */
    nav {
      position: fixed; top: 0; left: 0; right: 0;
      display: flex; justify-content: space-between; align-items: center;
      padding: 2rem 3rem;
      z-index: 100;
      transition: background 0.4s ease, backdrop-filter 0.4s ease, padding 0.4s ease, border-color 0.4s ease;
      border-bottom: 1px solid transparent;
    }
    nav.scrolled {
      background: rgba(10, 10, 8, 0.55);
      backdrop-filter: blur(18px);
      -webkit-backdrop-filter: blur(18px);
      padding: 1.2rem 3rem;
      border-bottom-color: rgba(200, 169, 110, 0.08);
    }
    .nav-logo {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.6rem;
      letter-spacing: 0.3em;
      color: var(--off-white);
      opacity: 0;
      animation: fadeInDown 1s ease 0.3s forwards;
    }
    .nav-right {
      display: flex;
      align-items: center;
      gap: 2.5rem;
      opacity: 0;
      animation: fadeInDown 1s ease 0.5s forwards;
    }
    .nav-link {
      font-family: 'Space Mono', monospace;
      font-size: 0.6rem;
      letter-spacing: 0.2em;
      color: rgba(240, 237, 230, 0.45);
      text-decoration: none;
      text-transform: uppercase;
      transition: color 0.3s;
    }
    .nav-link:hover { color: var(--gold); }
    .nav-tag {
      font-family: 'Space Mono', monospace;
      font-size: 0.65rem;
      letter-spacing: 0.2em;
      color: var(--gold);
      text-transform: uppercase;
    }

    /* ── HERO ── */
    .hero {
      min-height: 100vh;
      display: grid;
      grid-template-rows: 1fr auto;
      padding: 0 3rem 4rem;
      position: relative;
      overflow: hidden;
    }
    .hero-bg-text {
      position: absolute;
      bottom: -0.1em;
      left: -0.02em;
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(18vw, 26vw, 30vw);
      line-height: 0.85;
      color: transparent;
      -webkit-text-stroke: 1px rgba(200, 169, 110, 0.12);
      pointer-events: none;
      user-select: none;
      letter-spacing: -0.02em;
      opacity: 0;
      animation: revealStroke 1.4s ease 0.8s forwards;
    }
    .hero-content {
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      padding-top: 10rem;
      position: relative;
      z-index: 2;
    }
    .hero-eyebrow {
      font-family: 'Space Mono', monospace;
      font-size: 0.65rem;
      letter-spacing: 0.35em;
      color: var(--gold);
      text-transform: uppercase;
      margin-bottom: 2rem;
      opacity: 0;
      animation: fadeInUp 1s ease 1s forwards;
    }
    .hero-headline {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(5rem, 14vw, 13rem);
      line-height: 0.88;
      letter-spacing: -0.01em;
      color: var(--off-white);
      opacity: 0;
      animation: fadeInUp 1.2s ease 1.1s forwards;
    }
    .hero-headline em {
      font-style: normal;
      color: var(--gold);
      display: block;
    }
    .hero-sub {
      margin-top: 2.5rem;
      max-width: 480px;
      font-size: 1.2rem;
      font-weight: 300;
      line-height: 1.75;
      color: rgba(240, 237, 230, 0.6);
      opacity: 0;
      animation: fadeInUp 1s ease 1.3s forwards;
    }
    .hero-sub strong { color: var(--off-white); font-weight: 400; }
    .hero-bottom {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      position: relative;
      z-index: 2;
    }
    .scroll-hint {
      font-family: 'Space Mono', monospace;
      font-size: 0.6rem;
      letter-spacing: 0.3em;
      color: var(--muted);
      text-transform: uppercase;
      writing-mode: vertical-rl;
      transform: rotate(180deg);
      opacity: 0;
      animation: fadeIn 1s ease 2s forwards;
    }
    .hero-counter {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1rem;
      letter-spacing: 0.2em;
      color: var(--muted);
      opacity: 0;
      animation: fadeIn 1s ease 2s forwards;
    }

    /* ── DIVIDER ── */
    .divider {
      width: 100%;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--gold-dim), transparent);
      opacity: 0.4;
    }

    /* ── MANIFESTO ── */
    .manifesto {
      padding: 8rem 3rem;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 6rem;
      align-items: center;
      position: relative;
    }
    .manifesto-label {
      font-family: 'Space Mono', monospace;
      font-size: 0.6rem;
      letter-spacing: 0.4em;
      color: var(--gold);
      text-transform: uppercase;
      margin-bottom: 2rem;
    }
    .manifesto-text {
      font-size: clamp(1.6rem, 2.5vw, 2.2rem);
      font-weight: 300;
      font-style: italic;
      line-height: 1.65;
      color: var(--off-white);
    }
    .manifesto-text strong {
      font-style: normal;
      font-weight: 400;
      color: var(--gold);
    }
    .manifesto-right {
      border-left: 1px solid rgba(200, 169, 110, 0.2);
      padding-left: 4rem;
    }
    .manifesto-pillar { margin-bottom: 3rem; }
    .manifesto-pillar:last-child { margin-bottom: 0; }
    .pillar-number {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 3.5rem;
      color: rgba(200, 169, 110, 0.15);
      line-height: 1;
      margin-bottom: 0.5rem;
    }
    .pillar-title {
      font-family: 'Space Mono', monospace;
      font-size: 0.7rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 0.75rem;
    }
    .pillar-desc {
      font-size: 1rem;
      font-weight: 300;
      line-height: 1.8;
      color: rgba(240, 237, 230, 0.55);
    }

    /* ── VISION ── */
    .vision {
      padding: 8rem 3rem;
      background: rgba(200, 169, 110, 0.02);
      border-top: 1px solid rgba(200, 169, 110, 0.07);
      border-bottom: 1px solid rgba(200, 169, 110, 0.07);
    }
    .vision-inner {
      max-width: 1100px;
      margin: 0 auto;
    }
    .vision-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      margin-bottom: 5rem;
    }
    .vision-headline {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(3rem, 6vw, 5.5rem);
      line-height: 0.92;
      letter-spacing: 0.02em;
      color: var(--off-white);
    }
    .vision-headline span { color: var(--gold); }
    .vision-tagline {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.1rem;
      font-style: italic;
      font-weight: 300;
      color: rgba(240, 237, 230, 0.4);
      max-width: 280px;
      text-align: right;
      line-height: 1.6;
    }
    .vision-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 0;
      border: 1px solid rgba(200, 169, 110, 0.1);
    }
    .vision-block {
      padding: 3rem 2.5rem;
      border-right: 1px solid rgba(200, 169, 110, 0.1);
      position: relative;
      overflow: hidden;
      transition: background 0.4s ease;
    }
    .vision-block:last-child { border-right: none; }
    .vision-block::after {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 2px;
      background: var(--gold);
      transform: scaleX(0);
      transform-origin: left;
      transition: transform 0.6s ease;
    }
    .vision-block:hover { background: rgba(200, 169, 110, 0.04); }
    .vision-block:hover::after { transform: scaleX(1); }
    .vb-label {
      font-family: 'Space Mono', monospace;
      font-size: 0.58rem;
      letter-spacing: 0.4em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 1.5rem;
    }
    .vb-title {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 2rem;
      letter-spacing: 0.05em;
      color: var(--off-white);
      margin-bottom: 1.2rem;
      line-height: 1;
    }
    .vb-text {
      font-size: 1rem;
      font-weight: 300;
      line-height: 1.85;
      color: rgba(240, 237, 230, 0.5);
    }

    /* ── WHAT WE'RE BUILDING ── */
    .building {
      padding: 8rem 3rem;
      position: relative;
      overflow: hidden;
    }
    .building-bg {
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse 80% 50% at 20% 50%, rgba(200, 169, 110, 0.04) 0%, transparent 60%);
      pointer-events: none;
    }
    .building-inner {
      max-width: 1100px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 1.4fr;
      gap: 8rem;
      align-items: center;
      position: relative;
      z-index: 2;
    }
    .building-left {}
    .section-label {
      font-family: 'Space Mono', monospace;
      font-size: 0.6rem;
      letter-spacing: 0.4em;
      color: var(--gold);
      text-transform: uppercase;
      margin-bottom: 2rem;
    }
    .building-headline {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(2.5rem, 4.5vw, 4rem);
      line-height: 0.95;
      letter-spacing: 0.02em;
      color: var(--off-white);
      margin-bottom: 2rem;
    }
    .building-headline span { color: var(--gold); }
    .building-body {
      font-size: 1.1rem;
      font-weight: 300;
      line-height: 1.9;
      color: rgba(240, 237, 230, 0.55);
    }
    .building-body em {
      font-style: italic;
      color: rgba(240, 237, 230, 0.8);
    }
    .building-right {
      display: flex;
      flex-direction: column;
      gap: 1px;
      background: rgba(200, 169, 110, 0.08);
    }
    .build-item {
      background: var(--black);
      padding: 2rem 2.5rem;
      display: flex;
      gap: 2rem;
      align-items: flex-start;
      transition: background 0.3s;
    }
    .build-item:hover { background: rgba(200, 169, 110, 0.03); }
    .build-num {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.8rem;
      color: rgba(200, 169, 110, 0.2);
      line-height: 1;
      flex-shrink: 0;
      width: 2.5rem;
    }
    .build-content {}
    .build-title {
      font-family: 'Space Mono', monospace;
      font-size: 0.65rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--off-white);
      margin-bottom: 0.6rem;
    }
    .build-desc {
      font-size: 0.95rem;
      font-weight: 300;
      line-height: 1.75;
      color: rgba(240, 237, 230, 0.45);
    }

    /* ── QUOTE ── */
    .quote-strip {
      padding: 6rem 3rem;
      border-top: 1px solid rgba(200, 169, 110, 0.1);
      border-bottom: 1px solid rgba(200, 169, 110, 0.1);
      text-align: center;
      position: relative;
    }
    .quote-mark {
      font-family: 'Cormorant Garamond', serif;
      font-size: 8rem;
      line-height: 0;
      color: rgba(200, 169, 110, 0.15);
      position: absolute;
      top: 4rem;
      left: 3rem;
    }
    .quote-text {
      font-size: clamp(1.4rem, 3vw, 2.2rem);
      font-style: italic;
      font-weight: 300;
      line-height: 1.6;
      max-width: 700px;
      margin: 0 auto 1.5rem;
      color: var(--off-white);
    }
    .quote-attr {
      font-family: 'Space Mono', monospace;
      font-size: 0.6rem;
      letter-spacing: 0.4em;
      color: var(--gold);
      text-transform: uppercase;
    }

    /* ── COMMUNITY ── */
    .community {
      padding: 8rem 3rem;
      position: relative;
      overflow: hidden;
    }
    .community-bg {
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse 60% 60% at 50% 0%, rgba(200, 169, 110, 0.06) 0%, transparent 70%);
      pointer-events: none;
    }
    .community-inner {
      max-width: 860px;
      margin: 0 auto;
      text-align: center;
      position: relative;
      z-index: 2;
    }
    .community-label {
      font-family: 'Space Mono', monospace;
      font-size: 0.6rem;
      letter-spacing: 0.5em;
      color: var(--gold);
      text-transform: uppercase;
      margin-bottom: 1.5rem;
    }
    .community-headline {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(3rem, 7vw, 6rem);
      line-height: 0.92;
      letter-spacing: 0.02em;
      color: var(--off-white);
      margin-bottom: 2.5rem;
    }
    .community-headline span { color: var(--gold); }
    .community-body {
      font-size: 1.15rem;
      font-weight: 300;
      line-height: 1.85;
      color: rgba(240, 237, 230, 0.6);
      max-width: 620px;
      margin: 0 auto 4rem;
    }
    .community-body em { font-style: italic; color: var(--off-white); }
    .community-cards {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5px;
      margin-bottom: 5rem;
      border: 1px solid rgba(200, 169, 110, 0.12);
    }
    .c-card {
      padding: 2.5rem 2rem;
      background: rgba(200, 169, 110, 0.03);
      transition: background 0.4s ease;
      position: relative;
      overflow: hidden;
    }
    .c-card::before {
      content: '';
      position: absolute;
      bottom: 0; left: 0; right: 0;
      height: 1px;
      background: var(--gold);
      transform: scaleX(0);
      transform-origin: left;
      transition: transform 0.5s ease;
    }
    .c-card:hover { background: rgba(200, 169, 110, 0.07); }
    .c-card:hover::before { transform: scaleX(1); }
    .c-card-icon {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 2.5rem;
      color: rgba(200, 169, 110, 0.25);
      margin-bottom: 1rem;
      letter-spacing: 0.1em;
    }
    .c-card-title {
      font-family: 'Space Mono', monospace;
      font-size: 0.65rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 1rem;
    }
    .c-card-desc {
      font-size: 0.95rem;
      font-weight: 300;
      line-height: 1.75;
      color: rgba(240, 237, 230, 0.5);
    }

    /* ── EMAIL FORM ── */
    .form-wrapper {
      display: flex;
      gap: 0;
      max-width: 520px;
      margin: 0 auto;
      border: 1px solid rgba(200, 169, 110, 0.3);
      position: relative;
    }
    .form-wrapper::before {
      content: '';
      position: absolute;
      inset: -4px;
      border: 1px solid rgba(200, 169, 110, 0.08);
      pointer-events: none;
    }
    .email-input {
      flex: 1;
      background: transparent;
      border: none;
      outline: none;
      padding: 1.1rem 1.5rem;
      font-family: 'Space Mono', monospace;
      font-size: 0.7rem;
      letter-spacing: 0.1em;
      color: var(--off-white);
      caret-color: var(--gold);
    }
    .email-input::placeholder {
      color: rgba(240, 237, 230, 0.25);
      letter-spacing: 0.2em;
      text-transform: uppercase;
    }
    .email-btn {
      background: var(--gold);
      border: none;
      padding: 1.1rem 2rem;
      font-family: 'Space Mono', monospace;
      font-size: 0.65rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--black);
      cursor: crosshair;
      transition: background 0.3s ease;
      font-weight: 700;
    }
    .email-btn:hover { background: var(--off-white); }
    .form-note {
      margin-top: 1.2rem;
      font-family: 'Space Mono', monospace;
      font-size: 0.58rem;
      letter-spacing: 0.2em;
      color: rgba(240, 237, 230, 0.2);
      text-transform: uppercase;
    }

    /* ── FOOTER ── */
    footer {
      padding: 3rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-top: 1px solid rgba(240, 237, 230, 0.05);
    }
    .footer-logo {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.2rem;
      letter-spacing: 0.35em;
      color: rgba(240, 237, 230, 0.25);
    }
    .footer-copy {
      font-family: 'Space Mono', monospace;
      font-size: 0.55rem;
      letter-spacing: 0.2em;
      color: rgba(240, 237, 230, 0.2);
    }
    .footer-links {
      display: flex;
      gap: 2rem;
    }
    .footer-links a {
      font-family: 'Space Mono', monospace;
      font-size: 0.6rem;
      letter-spacing: 0.2em;
      color: rgba(240, 237, 230, 0.3);
      text-decoration: none;
      text-transform: uppercase;
      transition: color 0.3s;
    }
    .footer-links a:hover { color: var(--gold); }

    /* ── ANIMATIONS ── */
    @keyframes fadeInDown {
      from { opacity: 0; transform: translateY(-16px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes fadeInUp {
      from { opacity: 0; transform: translateY(24px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes fadeIn {
      from { opacity: 0; }
      to { opacity: 1; }
    }
    @keyframes revealStroke {
      from { opacity: 0; }
      to { opacity: 1; }
    }
    .reveal {
      opacity: 0;
      transform: translateY(30px);
      transition: opacity 0.9s ease, transform 0.9s ease;
    }
    .reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 768px) {
      nav { padding: 1.5rem; }
      .nav-right { gap: 1.2rem; }
      .nav-link { display: none; }
      .hero { padding: 0 1.5rem 3rem; }
      .manifesto { grid-template-columns: 1fr; gap: 3rem; padding: 5rem 1.5rem; }
      .manifesto-right { border-left: none; padding-left: 0; border-top: 1px solid rgba(200,169,110,0.2); padding-top: 3rem; }
      .vision { padding: 5rem 1.5rem; }
      .vision-header { flex-direction: column; align-items: flex-start; gap: 1.5rem; }
      .vision-tagline { text-align: left; }
      .vision-grid { grid-template-columns: 1fr; }
      .vision-block { border-right: none; border-bottom: 1px solid rgba(200,169,110,0.1); }
      .vision-block:last-child { border-bottom: none; }
      .building { padding: 5rem 1.5rem; }
      .building-inner { grid-template-columns: 1fr; gap: 3rem; }
      .community { padding: 5rem 1.5rem; }
      .community-cards { grid-template-columns: 1fr; }
      .quote-strip { padding: 4rem 1.5rem; }
      footer { flex-direction: column; gap: 1.5rem; text-align: center; padding: 2rem 1.5rem; }
      .footer-links { justify-content: center; }
    }
  </style>
</head>
<body>

  <!-- NAV -->
  <nav id="navbar">
    <div class="nav-logo">OUTLYR</div>
    <div class="nav-right">
      <a href="/blog" class="nav-link">Journal</a>
      <div class="nav-tag">Something is coming —</div>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-bg-text">OUTLYR</div>
    <div class="hero-content">
      <div class="hero-eyebrow">— Est. 2025 &nbsp;&nbsp;&nbsp; Not for everyone</div>
      <h1 class="hero-headline">
        Built<br>
        <em>Not Born.</em>
      </h1>
      <p class="hero-sub">
        Something is being made for those who <strong>refuse to inherit an identity</strong> — who forge it, day by day, through discipline and deliberate becoming.
      </p>
    </div>
    <div class="hero-bottom">
      <div class="scroll-hint">Scroll to explore</div>
      <div class="hero-counter">001 / 004</div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- MANIFESTO -->
  <section class="manifesto">
    <div class="manifesto-left reveal">
      <div class="manifesto-label">// The Premise</div>
      <p class="manifesto-text">
        Most people wear what they're told to wear.<br><br>
        We are making something for those who understand that <strong>every choice is a statement</strong> — and silence is the loudest one of all.
      </p>
    </div>
    <div class="manifesto-right reveal">
      <div class="manifesto-pillar">
        <div class="pillar-number">01</div>
        <div class="pillar-title">Intentionality</div>
        <p class="pillar-desc">Nothing created for Outlyr exists by accident. Every detail is a decision, made with the full weight of conviction.</p>
      </div>
      <div class="manifesto-pillar">
        <div class="pillar-number">02</div>
        <div class="pillar-title">Permanence</div>
        <p class="pillar-desc">Trends fade. We are building for the long game — things made to outlast the noise, the seasons, the cycles.</p>
      </div>
      <div class="manifesto-pillar">
        <div class="pillar-number">03</div>
        <div class="pillar-title">Identity</div>
        <p class="pillar-desc">You are not a demographic. Outlyr is for those who know who they are — and are still becoming more of it.</p>
      </div>
    </div>
  </section>

  <!-- VISION -->
  <section class="vision">
    <div class="vision-inner">
      <div class="vision-header reveal">
        <h2 class="vision-headline">
          The <span>Vision.</span><br>The Mission.
        </h2>
        <p class="vision-tagline">
          Where we're going, and why it matters to get there right.
        </p>
      </div>
      <div class="vision-grid">
        <div class="vision-block reveal">
          <div class="vb-label">// Vision</div>
          <div class="vb-title">A World That Builds Itself</div>
          <p class="vb-text">We envision a world where people stop inheriting their defaults — and start designing themselves. Where discipline is cultural, becoming is celebrated, and the builders are the ones who set the tone.</p>
        </div>
        <div class="vision-block reveal">
          <div class="vb-label">// Mission</div>
          <div class="vb-title">Tools for the Deliberate</div>
          <p class="vb-text">Outlyr exists to create objects, experiences, and community for those in the process of becoming. Everything we make is a tool — designed to remind you who you're building into, every single day.</p>
        </div>
        <div class="vision-block reveal">
          <div class="vb-label">// Identity</div>
          <div class="vb-title">Built, Not Assigned</div>
          <p class="vb-text">Outlyr is not a label to be worn — it's a position to be earned. You don't buy your way in. You live your way in. The brand is a reflection of the work, not a substitute for it.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- WHAT WE'RE BUILDING -->
  <section class="building">
    <div class="building-bg"></div>
    <div class="building-inner">
      <div class="building-left reveal">
        <div class="section-label">// What We're Working On</div>
        <h2 class="building-headline">
          Something<br>is being <span>made.</span>
        </h2>
        <p class="building-body">
          We're not ready to show you everything yet. But we can tell you this — <em>it's real, it's deliberate, and it's being built for people like you.</em><br><br>
          Not for the masses. Not for the algorithm. For the ones who are serious about who they're becoming.
        </p>
      </div>
      <div class="building-right reveal">
        <div class="build-item">
          <div class="build-num">I</div>
          <div class="build-content">
            <div class="build-title">A Product</div>
            <p class="build-desc">Something physical. Something with intention in every detail. Built to last, not to trend. More when it's ready.</p>
          </div>
        </div>
        <div class="build-item">
          <div class="build-num">II</div>
          <div class="build-content">
            <div class="build-title">A Community</div>
            <p class="build-desc">A private circle of builders — people who train, create, think, and build with purpose. Not a following. A foundation.</p>
          </div>
        </div>
        <div class="build-item">
          <div class="build-num">III</div>
          <div class="build-content">
            <div class="build-title">A Philosophy</div>
            <p class="build-desc">Documented in public. The thinking, the process, the failures, the becoming. A record of what it looks like to build without permission.</p>
          </div>
        </div>
        <div class="build-item">
          <div class="build-num">IV</div>
          <div class="build-content">
            <div class="build-title">A Journal</div>
            <p class="build-desc">Where the ideas live before they become real. Long-form. Unfiltered. Written for those who read to think, not to scroll.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- QUOTE -->
  <section class="quote-strip">
    <div class="quote-mark">"</div>
    <p class="quote-text reveal">
      The man who does not know himself has no identity to project — only borrowed signals from those around him.
    </p>
    <div class="quote-attr reveal">— The Outlyr Manifesto</div>
  </section>

  <!-- COMMUNITY -->
  <section class="community">
    <div class="community-bg"></div>
    <div class="community-inner">
      <div class="community-label reveal">// The Circle</div>
      <h2 class="community-headline reveal">
        A community of<br><span>deliberate builders</span>
      </h2>
      <p class="community-body reveal">
        Outlyr isn't just what we're making — it's <em>who we're building it for.</em>
        A closed circle of those who train, think, create, and build with intention.
        No noise. No performance. Just people who take themselves seriously.
      </p>
      <div class="community-cards">
        <div class="c-card reveal">
          <div class="c-card-icon">I</div>
          <div class="c-card-title">Inner Circle Access</div>
          <p class="c-card-desc">First access to everything Outlyr creates — before the world knows it exists.</p>
        </div>
        <div class="c-card reveal">
          <div class="c-card-icon">II</div>
          <div class="c-card-title">The Discipline Lab</div>
          <p class="c-card-desc">A private space for the builders — conversations on craft, discipline, and deliberate living.</p>
        </div>
        <div class="c-card reveal">
          <div class="c-card-icon">III</div>
          <div class="c-card-title">Behind the Build</div>
          <p class="c-card-desc">Unfiltered access into how Outlyr is being made — the decisions, the failures, the process.</p>
        </div>
      </div>
      <div class="form-wrapper reveal">
        <input class="email-input" type="email" placeholder="your@email.com" />
        <button class="email-btn" onclick="handleJoin()">Join the Circle</button>
      </div>
      <p class="form-note reveal">No newsletters. No spam. You'll only hear from us when it matters.</p>
    </div>
  </section>

  <!-- FOOTER -->
  <footer>
    <div class="footer-logo">OUTLYR</div>
    <div class="footer-copy">© 2025 Outlyr. All rights reserved.</div>
    <div class="footer-links">
      <a href="#">Instagram</a>
      <a href="#">X</a>
      <a href="/blog">Journal</a>
      <a href="#">Contact</a>
    </div>
  </footer>

  <script>
    const navbar = document.getElementById('navbar');

    const revealEls = document.querySelectorAll('.reveal');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          setTimeout(() => entry.target.classList.add('visible'), 80);
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.12 });
    revealEls.forEach(el => observer.observe(el));

    function handleJoin() {
      const input = document.querySelector('.email-input');
      const btn = document.querySelector('.email-btn');
      if (!input.value || !input.value.includes('@')) {
        input.style.borderLeft = '2px solid rgba(200,169,110,0.6)';
        return;
      }
      btn.textContent = "You're in.";
      btn.style.background = 'rgba(200,169,110,0.25)';
      btn.style.color = 'var(--gold)';
      input.value = '';
      input.placeholder = "We'll be in touch.";
      input.disabled = true;
    }

    const bgText = document.querySelector('.hero-bg-text');
    window.addEventListener('scroll', () => {
      const scrolled = window.scrollY;
      if (bgText) bgText.style.transform = `translateY(${scrolled * 0.25}px)`;
      navbar.classList.toggle('scrolled', scrolled > 40);
    });
  </script>
</body>
</html>