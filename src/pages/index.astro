---
import BaseLayout from '../layouts/BaseLayout.astro';

let applicantCount = 0;
let counterReady = false;
try {
  const res = await fetch(
    `${import.meta.env.PUBLIC_SUPABASE_URL}/rest/v1/circle_counter?select=count&id=eq.1`,
    {
      headers: {
        'apikey': import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
        'Authorization': `Bearer ${import.meta.env.PUBLIC_SUPABASE_ANON_KEY}`,
        'Content-Type': 'application/json',
        'Prefer': 'return=representation',
      }
    }
  );
  const data = await res.json();
  applicantCount = data[0]?.count ?? 0;
  counterReady = true;
} catch (e) {
  counterReady = false;
}
---

<BaseLayout title="OUTLYR — Built Not Born">

<!-- HERO -->
<section class="hero" style="border-top:none; padding-top:0;">
  <div class="hero-grid">
    <span></span><span></span><span></span><span></span>
    <span></span><span></span><span></span><span></span>
    <span></span><span></span><span></span><span></span>
  </div>
  <span class="hero-bg-word" id="heroBgWord">OUTLYR</span>
  <div class="hero-body">
    <p class="hero-kicker">// Not for everyone</p>
    <h1 class="hero-h1">
      Built<br><span class="hero-gold"><em>Not Born.</em></span>
    </h1>
    <div class="hero-statement">
      <p>
        For those who understand that <strong>who you are is not what you were given</strong> —
        it is what you have chosen, earned, and are still in the process of becoming.
        No audience required.
      </p>
      <div class="hero-actions">
        <a href="#craft" class="hero-cta">
          The brand <span>↓</span>
        </a>
        <a href="/the-circle" class="hero-cta hero-cta--ghost">
          The Circle <span>↗</span>
        </a>
      </div>
    </div>
  </div>
  <span class="hero-index">OUTLYR — 001 / 005 — IDENTITY</span>
</section>

<!-- BELIEF -->
<section class="belief reveal">
  <div class="belief-left">
    <p class="tag">01 — The Belief</p>
    <h2 class="sec-h2">Your ceiling<br>is <em>yours.</em></h2>
  </div>
  <div class="belief-right">
    <div class="belief-line reveal">
      <p>
        A quiet conviction that most people never fully test —
        <strong>that what you can become is largely self-determined.</strong>
        The variable is not talent, not birth, not circumstance.
        It is how much you are genuinely willing to put in.
      </p>
    </div>
    <div class="belief-line reveal">
      <p>
        You already know this. You've known it for a while.
        <strong>That's why you're still here, still at it</strong> — long after
        the people who started with you found reasons to stop.
        Outlyr doesn't give you this belief. It recognises it in you.
      </p>
    </div>
  </div>
</section>

<!-- ONE LEVEL DEEPER -->
<section class="deeper">
  <div class="deeper-top reveal">
    <div>
      <p class="tag">02 — The Marker</p>
      <h2 class="sec-h2">One level<br><em>deeper.</em></h2>
    </div>
    <p class="body-italic">
      The Outlyr mind doesn't react — it analyzes.
      Doesn't judge — it understands.<br><br>
      <strong>When everyone else has an opinion, the Outlyr person has a question:</strong>
      why is this happening, what does it reveal, what can be learned from it.
      That instinct — to go one level below the surface — is the sharpest marker of this tribe.
    </p>
  </div>

  <div class="contrast reveal">
    <div class="contrast-col">
      <p class="contrast-label">Everyone else</p>
      <ul>
        <li>Reacts to what happened</li>
        <li>Judges the person</li>
        <li>Talks about events</li>
        <li>Performs the journey</li>
        <li>Builds for the audience</li>
        <li>Stops when it gets hard</li>
      </ul>
    </div>
    <div class="contrast-col">
      <p class="contrast-label">The Outlyr mind</p>
      <ul>
        <li>Asks why it happened</li>
        <li>Studies the pattern</li>
        <li>Talks about ideas</li>
        <li>Lives the process quietly</li>
        <li>Builds for themselves</li>
        <li>Gets interesting when it gets hard</li>
      </ul>
    </div>
  </div>

  <div class="domains">
    <div class="domain reveal">
      <p class="domain-num">01</p>
      <h3>The Founder</h3>
      <p>Building something from nothing, in a space where nobody in their circle has done it before.</p>
    </div>
    <div class="domain reveal">
      <p class="domain-num">02</p>
      <h3>The Aspirant</h3>
      <p>Years of preparation, no guarantee, no shortcut — just the decision that this is the thing and this is the commitment.</p>
    </div>
    <div class="domain reveal">
      <p class="domain-num">03</p>
      <h3>The Creator</h3>
      <p>Building a body of work in a field where the path isn't linear and the validation doesn't come early.</p>
    </div>
    <div class="domain reveal">
      <p class="domain-num">04</p>
      <h3>The Athlete</h3>
      <p>Choosing a physical standard and holding it — not for competition, but because the discipline itself is the point.</p>
    </div>
  </div>
</section>

<!-- CONVICTION QUOTE -->
<section class="conviction reveal">
  <blockquote>
    "Identity is not inherited.<br>It is chosen, and then it is earned."
  </blockquote>
  <p class="conviction-sub">
    What you were born into — family, city, circumstance —
    that is the starting point. Not the ending one.
    In a country where birth is still widely treated as destiny,
    choosing otherwise is not just personal.<br>It is a position.
  </p>
  <cite>— The Outlyr Manifesto</cite>
</section>

<!-- THE CRAFT -->
<section class="craft" id="craft">
  <div class="craft-top reveal">
    <div>
      <p class="tag">03 — The Craft</p>
      <h2 class="sec-h2">Only<br><em>embroidery.</em></h2>
    </div>
    <p class="body-italic">
      Outlyr makes one kind of garment. Thread pushed through fabric, stitch by stitch.
      No print. No heat transfer. No shortcut.<br><br>
      <strong>The process is slower. The result doesn't wash out.</strong>
      Every piece is a decision about what goes on it — and embroidery holds
      that decision for years. That is the point.
    </p>
  </div>

  <div class="craft-specs reveal">
    <div class="spec">
      <span class="spec-label">Method</span>
      <span class="spec-value">Embroidery only</span>
    </div>
    <div class="spec">
      <span class="spec-label">Form</span>
      <span class="spec-value">Oversized, considered</span>
    </div>
    <div class="spec">
      <span class="spec-label">Run</span>
      <span class="spec-value">Limited, intentional</span>
    </div>
    <div class="spec">
      <span class="spec-label">Philosophy</span>
      <span class="spec-value">Built, not printed</span>
    </div>
    <div class="spec">
      <span class="spec-label">Origin</span>
      <span class="spec-value">India</span>
    </div>
  </div>

  <div class="craft-cards reveal">
    <div class="craft-card">
      <p>
        Most streetwear is printed. Fast, cheap, disposable.
        Print fades. Heat transfers crack. The garment becomes a record of its own degradation.
      </p>
    </div>
    <div class="craft-card">
      <p>
        Embroidery is the opposite. It is stitched in.
        <strong>The piece you wear five years from now looks like the decision you made when you bought it.</strong>
        Outlyr only makes things that hold.
      </p>
    </div>
  </div>
</section>

<!-- THE OBJECT — phygital teaser -->
<section class="object">
  <div class="object-inner">
    <p class="tag reveal">04 — The Object</p>
    <h2 class="object-h2 reveal">The piece<br><em>continues.</em></h2>
    <div class="object-body-wrap reveal">
      <p class="object-body">
        Every Outlyr garment carries something inside it.
        Not visible from outside. Not on the label. Not explained anywhere.
      </p>
      <p class="object-body">
        <strong>At some point, you will encounter it.</strong>
        What it tells you — depends on where you are in the story.
      </p>
    </div>
    <div class="object-divider reveal"></div>
    <p class="object-sub reveal">// This is not a garment you wear and forget.</p>
  </div>
</section>

<!-- CIRCLE TEASER -->
<section class="circle-teaser">
  <div class="circle-teaser-grid">
    <div class="reveal">
      <p class="tag">05 — The Circle</p>
      <h2 class="sec-h2">A private<br>room for<br><em>builders.</em></h2>
    </div>
    <div class="circle-right reveal">
      <p class="body-italic">
        The Circle is where the Outlyr tribe actually exists.
        Character-filtered. Application-based.
        <strong>Not open to most people.</strong><br><br>
        If you are building something, pursuing something, or becoming something —
        and you want a room that operates at that level — apply.
        The standard is held. Always.
      </p>
      {counterReady && applicantCount > 0 && (
        <div class="counter-block">
          <span class="counter-num">{applicantCount}</span>
          <span class="counter-label">people have applied</span>
        </div>
      )}
      <a href="/the-circle" class="btn-gold">
        Apply to The Circle <span>↗</span>
      </a>
      <a href="https://instagram.com/outlyr.in" target="_blank" class="btn-outline">
        Follow the build &nbsp;<span class="btn-handle">@outlyr.in</span>
      </a>
    </div>
  </div>
</section>

</BaseLayout>

<style>
  /* ─── KEYFRAMES ─── */
  @keyframes up {
    from { opacity: 0; transform: translateY(32px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes fadeIn { to { opacity: 1; } }

  /* ─── TYPE HELPERS (page-local) ─── */
  .sec-h2 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(56px, 7vw, 108px);
    line-height: 0.88; letter-spacing: 0.01em; margin-top: 28px;
  }
  .sec-h2 em { color: var(--acc); font-style: italic; }

  .body-italic {
    font-size: clamp(20px, 2vw, 25px);
    line-height: 1.78; font-style: italic; color: var(--t55);
  }
  .body-italic strong { color: var(--tx); font-style: normal; font-weight: 600; }

  /* ─── HERO ─── */
  .hero {
    min-height: 100svh;
    display: grid; grid-template-rows: 1fr auto;
    position: relative; overflow: hidden;
    padding: 0 56px;
  }
  .hero-grid {
    position: absolute; inset: 0; pointer-events: none;
    display: grid; grid-template-columns: repeat(12, 1fr);
  }
  .hero-grid span { border-right: 1px solid var(--a10); }
  .hero-grid span:first-child { border-left: 1px solid var(--a10); }

  .hero-bg-word {
    position: absolute; bottom: -0.05em; right: -0.02em;
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(22vw, 28vw, 34vw); line-height: 0.85;
    color: transparent; -webkit-text-stroke: 1px rgba(200,184,154,0.03);
    pointer-events: none; user-select: none;
    letter-spacing: -0.01em; z-index: 1; will-change: transform;
  }
  .hero-body {
    display: flex; flex-direction: column;
    justify-content: flex-end; padding-bottom: 80px;
    position: relative; z-index: 2; max-width: 900px;
  }
  .hero-kicker {
    font-family: 'DM Mono', monospace;
    font-size: 15px; letter-spacing: 0.28em; text-transform: uppercase;
    color: var(--acc); margin-bottom: 36px;
    display: flex; align-items: center; gap: 16px;
    opacity: 0; animation: up 0.7s ease forwards 0.2s;
  }
  .hero-kicker::before {
    content: ''; width: 32px; height: 1px; background: var(--a40); display: block;
  }
  .hero-h1 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(96px, 14vw, 210px);
    line-height: 0.86; letter-spacing: 0.01em;
    opacity: 0; animation: up 1s ease forwards 0.4s;
  }
  .hero-gold { color: var(--acc); }
  .hero-statement {
    margin-top: 52px; max-width: 600px;
    opacity: 0; animation: up 0.8s ease forwards 0.75s;
  }
  .hero-statement p {
    font-size: clamp(22px, 2.2vw, 28px);
    line-height: 1.68; font-style: italic; color: var(--t55);
  }
  .hero-statement p strong { color: var(--tx); font-style: normal; font-weight: 600; }

  .hero-actions {
    display: flex; gap: 16px; flex-wrap: wrap; margin-top: 48px;
    opacity: 0; animation: up 0.8s ease forwards 1.05s;
  }
  .hero-cta {
    display: inline-flex; align-items: center; gap: 12px;
    border: 1px solid var(--a40); padding: 16px 44px;
    font-family: 'DM Mono', monospace;
    font-size: 10px; letter-spacing: 0.28em; text-transform: uppercase;
    color: var(--acc); text-decoration: none;
    transition: background 0.3s, border-color 0.3s, color 0.3s;
  }
  .hero-cta:hover { background: var(--a05); border-color: var(--acc); color: var(--tx); }
  .hero-cta span { font-size: 13px; transition: transform 0.3s; }
  .hero-cta:hover span { transform: translate(3px, -3px); }
  .hero-cta--ghost { border-color: var(--a20); color: var(--t55); }
  .hero-cta--ghost:hover { border-color: var(--a40); color: var(--tx); background: var(--a05); }

  .hero-index {
    position: absolute; right: 56px; bottom: 80px;
    font-family: 'DM Mono', monospace;
    font-size: 9px; letter-spacing: 0.22em;
    color: var(--t30); z-index: 2; writing-mode: vertical-rl;
    opacity: 0; animation: fadeIn 1s ease forwards 1.2s;
  }

  /* ─── BELIEF ─── */
  .belief {
    background: var(--bg2);
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 80px; align-items: center;
  }
  .belief-right { display: flex; flex-direction: column; gap: 32px; }
  .belief-line {
    padding: 32px 36px; border: 1px solid var(--a10);
    position: relative; transition: border-color 0.4s, background 0.4s;
  }
  .belief-line:hover { border-color: var(--a20); background: var(--a05); }
  .belief-line::before {
    content: ''; position: absolute; top: 0; left: 0;
    width: 2px; height: 0; background: var(--acc); transition: height 0.5s ease;
  }
  .belief-line:hover::before { height: 100%; }
  .belief-line p {
    font-size: clamp(20px, 1.9vw, 24px);
    line-height: 1.75; font-style: italic; color: var(--t55);
  }
  .belief-line p strong { color: var(--tx); font-style: normal; font-weight: 600; }

  /* ─── DEEPER ─── */
  .deeper-top {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 80px; margin-bottom: 88px; align-items: end;
  }
  .contrast {
    display: grid; grid-template-columns: 1fr 1fr;
    border: 1px solid var(--a10); margin-bottom: 80px;
  }
  .contrast-col { padding: 52px 48px; }
  .contrast-col:first-child { border-right: 1px solid var(--a10); }
  .contrast-label {
    font-family: 'DM Mono', monospace;
    font-size: 15px; letter-spacing: 0.28em; text-transform: uppercase; margin-bottom: 28px;
  }
  .contrast-col:first-child .contrast-label { color: var(--t30); }
  .contrast-col:last-child .contrast-label { color: var(--acc); }
  .contrast-col ul { list-style: none; display: flex; flex-direction: column; gap: 16px; }
  .contrast-col ul li {
    font-size: 17px; line-height: 1.7; font-style: italic; color: var(--t30);
    padding-left: 20px; position: relative;
  }
  .contrast-col:last-child ul li { color: var(--t55); }
  .contrast-col ul li::before { content: '—'; position: absolute; left: 0; color: var(--a40); }

  .domains { display: grid; grid-template-columns: repeat(4, 1fr); gap: 2px; }
  .domain {
    padding: 44px 36px; border: 1px solid var(--a10);
    transition: background 0.4s, border-color 0.4s;
    position: relative; overflow: hidden;
  }
  .domain:hover { background: var(--a05); border-color: var(--a20); }
  .domain::after {
    content: ''; position: absolute; bottom: 0; left: 0; right: 0;
    height: 1px; background: var(--acc);
    transform: scaleX(0); transform-origin: left; transition: transform 0.5s ease;
  }
  .domain:hover::after { transform: scaleX(1); }
  .domain-num {
    font-family: 'DM Mono', monospace;
    font-size: 8px; letter-spacing: 0.25em; color: var(--acc); margin-bottom: 20px;
  }
  .domain h3 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 28px; letter-spacing: 0.08em; color: var(--tx); margin-bottom: 12px;
  }
  .domain p { font-size: 20px; line-height: 1.8; color: var(--t30); font-style: italic; }

  /* ─── CONVICTION ─── */
  .conviction {
    background: var(--bg2); text-align: center;
    overflow: hidden; padding: 160px 56px;
  }
  .conviction::before {
    content: '"'; position: absolute; top: -80px; left: 50%;
    transform: translateX(-50%);
    font-family: 'Cormorant Garamond', serif;
    font-size: 480px; line-height: 1;
    color: rgba(200,184,154,0.03); pointer-events: none;
  }
  .conviction blockquote {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(30px, 3.5vw, 48px);
    font-style: italic; font-weight: 300; line-height: 1.45; color: var(--tx);
    max-width: 840px; margin: 0 auto 20px; position: relative; z-index: 1;
  }
  .conviction blockquote em { color: var(--acc); }
  .conviction-sub {
    font-size: clamp(20px, 1.8vw, 22px); line-height: 1.7; font-style: italic;
    color: var(--t30); max-width: 560px; margin: 0 auto 40px; position: relative; z-index: 1;
  }
  .conviction cite {
    font-family: 'DM Mono', monospace;
    font-size: 12px; letter-spacing: 0.25em; text-transform: uppercase;
    color: var(--a40); font-style: normal; position: relative; z-index: 1;
  }

  /* ─── CRAFT ─── */
  .craft { background: var(--bg); }

  .craft-top {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 80px; margin-bottom: 80px; align-items: end;
  }

  .craft-specs {
    display: grid; grid-template-columns: repeat(5, 1fr);
    border: 1px solid var(--a10);
    margin-bottom: 64px;
  }
  .spec {
    padding: 40px 32px;
    border-right: 1px solid var(--a10);
    display: flex; flex-direction: column; gap: 16px;
    transition: background 0.3s;
  }
  .spec:last-child { border-right: none; }
  .spec:hover { background: var(--a05); }
  .spec-label {
    font-family: 'DM Mono', monospace;
    font-size: 9px; letter-spacing: 0.28em; text-transform: uppercase; color: var(--t30);
  }
  .spec-value {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(17px, 1.6vw, 22px); font-style: italic; color: var(--tx); line-height: 1.3;
  }

  .craft-cards {
    display: grid; grid-template-columns: 1fr 1fr; gap: 2px;
  }
  .craft-card {
    padding: 48px 44px; border: 1px solid var(--a10);
    position: relative; transition: border-color 0.4s, background 0.4s;
  }
  .craft-card:hover { border-color: var(--a20); background: var(--a05); }
  .craft-card::before {
    content: ''; position: absolute; top: 0; left: 0;
    width: 2px; height: 0; background: var(--acc); transition: height 0.5s ease;
  }
  .craft-card:hover::before { height: 100%; }
  .craft-card p {
    font-size: clamp(19px, 1.7vw, 23px);
    line-height: 1.78; color: var(--t55); font-style: italic;
  }
  .craft-card p strong { color: var(--tx); font-style: normal; font-weight: 600; }

  /* ─── OBJECT ─── */
  .object {
    background: var(--bg3);
    text-align: center;
    overflow: hidden;
    padding: 160px 56px;
    position: relative;
  }
  .object::before {
    content: 'OBJECT';
    position: absolute; top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    font-family: 'Bebas Neue', sans-serif;
    font-size: 30vw; letter-spacing: 0.05em;
    color: transparent;
    -webkit-text-stroke: 1px rgba(200,184,154,0.025);
    pointer-events: none; user-select: none; white-space: nowrap; line-height: 1;
  }
  .object-inner { position: relative; z-index: 1; }
  .object-h2 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(72px, 11vw, 160px);
    line-height: 0.88; letter-spacing: 0.01em;
    margin: 40px auto 0;
  }
  .object-h2 em { color: var(--acc); font-style: italic; }
  .object-body-wrap {
    max-width: 560px; margin: 64px auto 0;
    display: flex; flex-direction: column; gap: 24px;
  }
  .object-body {
    font-size: clamp(19px, 1.8vw, 24px);
    line-height: 1.78; font-style: italic; color: var(--t55);
  }
  .object-body strong { color: var(--tx); font-style: normal; font-weight: 600; }
  .object-divider {
    width: 1px; height: 56px;
    background: linear-gradient(to bottom, var(--a40), transparent);
    margin: 56px auto 44px;
  }
  .object-sub {
    font-family: 'DM Mono', monospace;
    font-size: 12px; letter-spacing: 0.28em; text-transform: uppercase; color: var(--acc);
  }

  /* ─── CIRCLE TEASER ─── */
  .circle-teaser-grid {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 80px; align-items: start;
  }
  .circle-right {
    display: flex; flex-direction: column;
    align-items: flex-start; gap: 32px;
  }

  .counter-block {
    display: flex; align-items: center; gap: 14px;
    padding: 24px 36px; border: 1px solid var(--a10);
    position: relative; width: 100%; max-width: 320px;
  }
  .counter-block::before {
    content: ''; position: absolute; top: 0; left: 0;
    width: 2px; height: 100%; background: var(--acc);
  }
  .counter-num {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(44px, 5vw, 64px);
    line-height: 1; color: var(--acc); letter-spacing: 0.02em;
  }
  .counter-label {
    font-family: 'DM Mono', monospace;
    font-size: 9px; letter-spacing: 0.28em; text-transform: uppercase;
    color: var(--t30); line-height: 1.6; max-width: 100px;
  }

  .btn-gold {
    display: inline-flex; align-items: center; gap: 12px;
    border: 1px solid var(--a40); padding: 18px 48px;
    font-family: 'DM Mono', monospace;
    font-size: 10px; letter-spacing: 0.28em; text-transform: uppercase;
    color: var(--acc); text-decoration: none;
    transition: background 0.3s, border-color 0.3s, color 0.3s;
  }
  .btn-gold:hover { background: var(--a05); border-color: var(--acc); color: var(--tx); }
  .btn-gold span { font-size: 13px; transition: transform 0.3s; }
  .btn-gold:hover span { transform: translate(3px, -3px); }

  .btn-outline {
