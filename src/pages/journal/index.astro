---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<BaseLayout title="Journal — OUTLYR" activeNav="journal">

  <header class="page-header">
    <div class="page-header-bg">JOURNAL</div>
    <div class="page-eyebrow">// The Outlyr Journal</div>
    <h1 class="page-title">Ideas<br>Before<br>They're Real.</h1>
    <p class="page-desc">Long-form writing on discipline, identity, building, and the process of deliberate becoming.</p>
    <div class="post-count">{posts.length.toString().padStart(3, '0')} Entries</div>
  </header>

  <main>
    {posts.length === 0 ? (
      <div class="posts-grid">
        <div class="empty">
          <p>Nothing here yet. The first entry is being written.</p>
        </div>
      </div>
    ) : (
      <div class="posts-grid">
        {posts.map((post, index) => (
          <a href={`/journal/${post.id}/`} class="post-card reveal">
            <div class="post-image">
              {post.data.heroImage
                ? <img src={post.data.heroImage} alt={post.data.title} />
                : <div class="post-image-placeholder"><span>OUTLYR</span></div>
              }
            </div>
            <div class="post-body">
              <div class="post-number">{(index + 1).toString().padStart(2, '0')}</div>
              <div class="post-meta">{formatDate(post.data.pubDate)}</div>
              <h2 class="post-title">{post.data.title}</h2>
              {post.data.description && (
                <p class="post-excerpt">{post.data.description}</p>
              )}
              <span class="post-link">Read entry</span>
            </div>
          </a>
        ))}
      </div>
    )}
  </main>

</BaseLayout>

<style>
  /* ── PAGE HEADER ── */
  .page-header {
    padding: 14rem 56px 5rem;
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--a10);
  }
  .page-header-bg {
    position: absolute;
    bottom: -0.1em; right: -0.02em;
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(12vw, 18vw, 22vw);
    line-height: 0.85; color: transparent;
    -webkit-text-stroke: 1px rgba(200,184,154,0.05);
    pointer-events: none; user-select: none;
    letter-spacing: -0.02em;
  }
  .page-eyebrow {
    font-family: 'DM Mono', monospace;
    font-size: 11px; letter-spacing: 0.4em;
    color: var(--acc); text-transform: uppercase;
    margin-bottom: 1.5rem;
  }
  .page-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(4rem, 10vw, 9rem);
    line-height: 0.9; letter-spacing: 0.02em;
    color: var(--tx); margin-bottom: 2rem;
  }
  .page-desc {
    font-size: clamp(18px, 1.8vw, 22px);
    font-weight: 300; font-style: italic;
    line-height: 1.75; color: var(--t55);
    max-width: 500px;
  }
  .post-count {
    position: absolute; bottom: 3rem; right: 56px;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1rem; letter-spacing: 0.2em;
    color: var(--t30);
  }

  /* ── MAIN ── */
  main {
    padding: 5rem 56px;
    max-width: 1400px;
    width: 100%;
    margin: 0 auto;
  }

  /* ── GRID ── */
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 1px;
    background: var(--a10);
  }

  .post-card {
    grid-column: span 6;
    background: var(--bg);
    display: flex; flex-direction: column;
    position: relative;
    text-decoration: none; color: inherit;
    transition: background 0.4s ease;
  }
  .post-card:first-child {
    grid-column: span 12;
    display: grid;
    grid-template-columns: 1fr 1fr;
  }
  .post-card:hover { background: var(--a05); }

  /* ── IMAGE ── */
  .post-image {
    width: 100%; aspect-ratio: 16/9;
    overflow: hidden; position: relative;
  }
  .post-card:first-child .post-image {
    aspect-ratio: auto; min-height: 360px;
  }
  .post-image img {
    width: 100%; height: 100%; object-fit: cover; display: block;
    filter: grayscale(20%) brightness(0.85);
    transition: filter 0.6s ease, transform 0.6s ease;
  }
  .post-card:hover .post-image img {
    filter: grayscale(0%) brightness(0.95);
    transform: scale(1.03);
  }
  .post-image-placeholder {
    width: 100%; height: 100%;
    background: var(--a05);
    display: flex; align-items: center; justify-content: center;
    min-height: 200px;
  }
  .post-image-placeholder span {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 4rem; color: var(--a20);
    letter-spacing: 0.1em;
  }

  /* ── BODY ── */
  .post-body {
    padding: 2.5rem;
    display: flex; flex-direction: column; flex: 1;
    position: relative;
  }
  .post-card:first-child .post-body {
    justify-content: center; padding: 3.5rem;
  }
  .post-card:first-child .post-body::before {
    content: 'Featured';
    font-family: 'DM Mono', monospace;
    font-size: 9px; letter-spacing: 0.4em;
    text-transform: uppercase; color: var(--acc);
    margin-bottom: 1.5rem; display: block;
  }
  .post-number {
    position: absolute; top: 2rem; right: 2.5rem;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 3rem; color: var(--a10);
    line-height: 1; pointer-events: none;
  }
  .post-meta {
    font-family: 'DM Mono', monospace;
    font-size: 9px; letter-spacing: 0.2em;
    color: var(--t30); text-transform: uppercase;
    margin-bottom: 1rem;
  }
  .post-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(1.8rem, 3vw, 2.8rem);
    line-height: 0.95; letter-spacing: 0.02em;
    color: var(--tx); margin-bottom: 1.2rem;
    transition: color 0.3s;
  }
  .post-card:first-child .post-title { font-size: clamp(2.5rem, 4vw, 4rem); }
  .post-card:hover .post-title { color: var(--acc); }
  .post-excerpt {
    font-size: clamp(17px, 1.5vw, 20px);
    font-weight: 300; font-style: italic;
    line-height: 1.8; color: var(--t55);
    flex: 1; margin-bottom: 2rem;
  }
  .post-link {
    display: inline-flex; align-items: center; gap: 0.75rem;
    font-family: 'DM Mono', monospace;
    font-size: 9px; letter-spacing: 0.3em; text-transform: uppercase;
    color: var(--acc); text-decoration: none;
    transition: gap 0.3s ease; align-self: flex-start;
  }
  .post-link::after { content: '→'; transition: transform 0.3s ease; }
  .post-link:hover { gap: 1.2rem; }
  .post-link:hover::after { transform: translateX(4px); }

  /* ── EMPTY ── */
  .empty {
    grid-column: span 12;
    padding: 6rem 3rem; text-align: center;
    background: var(--bg);
  }
  .empty p {
    font-size: clamp(22px, 2vw, 28px);
    font-style: italic; font-weight: 300;
    color: var(--t30);
  }

  /* ── REVEAL — self-contained, uses .visible not .on ── */
  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }
  .reveal.visible { opacity: 1; transform: none; }

  /* ── RESPONSIVE ── */
  @media (max-width: 960px) {
    .page-header { padding: 10rem 24px 4rem; }
    .post-count { right: 24px; }
    main { padding: 3rem 24px; }
    .post-card, .post-card:first-child { grid-column: span 12; grid-template-columns: 1fr; }
    .post-card:first-child .post-image { min-height: 240px; }
  }
</style>

<script is:inline>
  // Nav
  var navbar = document.querySelector('nav');
  if (navbar) {
    navbar.classList.add('frosted');
    window.addEventListener('scroll', function() {
      navbar.classList.toggle('scrolled', window.scrollY > 40);
    });
  }

  // Reveal — uses .visible, completely independent
  var revealEls = document.querySelectorAll('.reveal');
  var observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry, i) {
      if (entry.isIntersecting) {
        setTimeout(function() {
          entry.target.classList.add('visible');
        }, i * 100);
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.08 });
  revealEls.forEach(function(el) { observer.observe(el); });
</script>