---
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Journal — OUTLYR</title>
  <meta name="description" content="Long-form writing from Outlyr. Ideas before they become real." />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --black: #0a0a08;
      --off-white: #f0ede6;
      --gold: #c8a96e;
      --gold-dim: #8a6e3e;
      --muted: #3a3830;
    }

    html { scroll-behavior: smooth; }

    body {
      background-color: var(--black);
      color: var(--off-white);
      font-family: 'Cormorant Garamond', serif;
      overflow-x: hidden;
      cursor: crosshair;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    body::before {
      content: '';
      position: fixed; inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='1'/%3E%3C/svg%3E");
      opacity: 0.045;
      pointer-events: none;
      z-index: 9999;
    }

    /* ── NAV ── */
    nav {
      position: fixed; top: 0; left: 0; right: 0;
      display: flex; justify-content: space-between; align-items: center;
      padding: 2rem 3rem;
      z-index: 100;
      transition: background 0.4s ease, padding 0.4s ease, border-color 0.4s ease;
      border-bottom: 1px solid transparent;
    }
    nav.scrolled {
      background: rgba(10, 10, 8, 0.75);
      backdrop-filter: blur(18px);
      -webkit-backdrop-filter: blur(18px);
      padding: 1.2rem 3rem;
      border-bottom-color: rgba(200, 169, 110, 0.08);
    }
    .nav-logo {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.6rem;
      letter-spacing: 0.3em;
      color: var(--off-white);
      text-decoration: none;
    }
    .nav-right {
      display: flex;
      align-items: center;
      gap: 2.5rem;
    }
    .nav-link {
      font-family: 'Space Mono', monospace;
      font-size: 0.6rem;
      letter-spacing: 0.2em;
      color: rgba(240, 237, 230, 0.45);
      text-decoration: none;
      text-transform: uppercase;
      transition: color 0.3s;
    }
    .nav-link:hover, .nav-link.active { color: var(--gold); }

    /* ── HEADER ── */
    .page-header {
      padding: 14rem 3rem 5rem;
      position: relative;
      overflow: hidden;
      border-bottom: 1px solid rgba(200, 169, 110, 0.1);
    }
    .page-header-bg {
      position: absolute;
      bottom: -0.1em;
      right: -0.02em;
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(12vw, 18vw, 22vw);
      line-height: 0.85;
      color: transparent;
      -webkit-text-stroke: 1px rgba(200, 169, 110, 0.07);
      pointer-events: none;
      user-select: none;
      letter-spacing: -0.02em;
    }
    .page-eyebrow {
      font-family: 'Space Mono', monospace;
      font-size: 0.6rem;
      letter-spacing: 0.4em;
      color: var(--gold);
      text-transform: uppercase;
      margin-bottom: 1.5rem;
    }
    .page-title {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(4rem, 10vw, 9rem);
      line-height: 0.9;
      letter-spacing: 0.02em;
      color: var(--off-white);
      margin-bottom: 2rem;
    }
    .page-desc {
      font-size: 1.15rem;
      font-weight: 300;
      font-style: italic;
      line-height: 1.75;
      color: rgba(240, 237, 230, 0.5);
      max-width: 500px;
    }
    .post-count {
      position: absolute;
      bottom: 3rem;
      right: 3rem;
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1rem;
      letter-spacing: 0.2em;
      color: var(--muted);
    }

    /* ── POSTS GRID ── */
    main {
      flex: 1;
      padding: 5rem 3rem;
      max-width: 1200px;
      width: 100%;
      margin: 0 auto;
    }

    .posts-grid {
      display: grid;
      grid-template-columns: repeat(12, 1fr);
      gap: 1px;
      background: rgba(200, 169, 110, 0.08);
    }

    /* Featured post — full width */
    .post-card:first-child {
      grid-column: span 12;
      display: grid;
      grid-template-columns: 1fr 1fr;
    }

    /* Regular posts — half width */
    .post-card {
      grid-column: span 6;
      background: var(--black);
      display: flex;
      flex-direction: column;
    }

    .post-image {
      width: 100%;
      aspect-ratio: 16/9;
      overflow: hidden;
      position: relative;
    }
    .post-card:first-child .post-image {
      aspect-ratio: auto;
      min-height: 360px;
    }
    .post-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      filter: grayscale(20%) brightness(0.85);
      transition: filter 0.6s ease, transform 0.6s ease;
    }
    .post-card:hover .post-image img {
      filter: grayscale(0%) brightness(0.95);
      transform: scale(1.03);
    }
    .post-image-placeholder {
      width: 100%;
      height: 100%;
      background: rgba(200, 169, 110, 0.04);
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .post-image-placeholder span {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 4rem;
      color: rgba(200, 169, 110, 0.12);
      letter-spacing: 0.1em;
    }

    .post-body {
      padding: 2.5rem;
      display: flex;
      flex-direction: column;
      flex: 1;
      position: relative;
    }
    .post-card:first-child .post-body {
      justify-content: center;
      padding: 3.5rem;
    }
    .post-card:first-child .post-body::before {
      content: 'Featured';
      font-family: 'Space Mono', monospace;
      font-size: 0.55rem;
      letter-spacing: 0.4em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 1.5rem;
      display: block;
    }

    .post-meta {
      font-family: 'Space Mono', monospace;
      font-size: 0.58rem;
      letter-spacing: 0.2em;
      color: var(--muted);
      text-transform: uppercase;
      margin-bottom: 1rem;
    }
    .post-title {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(1.8rem, 3vw, 2.8rem);
      line-height: 0.95;
      letter-spacing: 0.02em;
      color: var(--off-white);
      margin-bottom: 1.2rem;
      transition: color 0.3s;
    }
    .post-card:first-child .post-title {
      font-size: clamp(2.5rem, 4vw, 4rem);
    }
    .post-card:hover .post-title { color: var(--gold); }
    .post-excerpt {
      font-size: 1rem;
      font-weight: 300;
      line-height: 1.8;
      color: rgba(240, 237, 230, 0.5);
      flex: 1;
      margin-bottom: 2rem;
    }
    .post-link {
      display: inline-flex;
      align-items: center;
      gap: 0.75rem;
      font-family: 'Space Mono', monospace;
      font-size: 0.6rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--gold);
      text-decoration: none;
      transition: gap 0.3s ease;
      align-self: flex-start;
    }
    .post-link::after {
      content: '→';
      transition: transform 0.3s ease;
    }
    .post-link:hover { gap: 1.2rem; }
    .post-link:hover::after { transform: translateX(4px); }
    .post-number {
      position: absolute;
      top: 2rem;
      right: 2.5rem;
      font-family: 'Bebas Neue', sans-serif;
      font-size: 3rem;
      color: rgba(200, 169, 110, 0.07);
      line-height: 1;
      pointer-events: none;
    }

    /* Hover overlay on card */
    .post-card {
      position: relative;
      transition: background 0.4s ease;
      text-decoration: none;
      color: inherit;
    }
    .post-card:hover { background: rgba(200, 169, 110, 0.025); }

    /* ── EMPTY STATE ── */
    .empty {
      grid-column: span 12;
      padding: 6rem 3rem;
      text-align: center;
      background: var(--black);
    }
    .empty p {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.4rem;
      font-style: italic;
      font-weight: 300;
      color: rgba(240, 237, 230, 0.3);
    }

    /* ── FOOTER ── */
    footer {
      padding: 3rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-top: 1px solid rgba(240, 237, 230, 0.05);
      margin-top: auto;
    }
    .footer-logo {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.2rem;
      letter-spacing: 0.35em;
      color: rgba(240, 237, 230, 0.25);
      text-decoration: none;
    }
    .footer-copy {
      font-family: 'Space Mono', monospace;
      font-size: 0.55rem;
      letter-spacing: 0.2em;
      color: rgba(240, 237, 230, 0.2);
    }
    .footer-links {
      display: flex;
      gap: 2rem;
    }
    .footer-links a {
      font-family: 'Space Mono', monospace;
      font-size: 0.6rem;
      letter-spacing: 0.2em;
      color: rgba(240, 237, 230, 0.3);
      text-decoration: none;
      text-transform: uppercase;
      transition: color 0.3s;
    }
    .footer-links a:hover { color: var(--gold); }

    /* ── ANIMATIONS ── */
    .reveal {
      opacity: 0;
      transform: translateY(24px);
      transition: opacity 0.8s ease, transform 0.8s ease;
    }
    .reveal.visible { opacity: 1; transform: translateY(0); }

    /* ── RESPONSIVE ── */
    @media (max-width: 900px) {
      .post-card:first-child { grid-template-columns: 1fr; }
      .post-card:first-child .post-image { min-height: 240px; }
    }
    @media (max-width: 768px) {
      nav { padding: 1.5rem; }
      nav.scrolled { padding: 1rem 1.5rem; }
      .page-header { padding: 10rem 1.5rem 4rem; }
      main { padding: 3rem 1.5rem; }
      .post-card, .post-card:first-child { grid-column: span 12; }
      .post-card:first-child { grid-template-columns: 1fr; }
      footer { flex-direction: column; gap: 1.5rem; text-align: center; padding: 2rem 1.5rem; }
      .footer-links { justify-content: center; }
    }
  </style>
</head>
<body>

  <nav id="navbar">
    <a href="/" class="nav-logo">OUTLYR</a>
    <div class="nav-right">
      <a href="/" class="nav-link">Home</a>
      <a href="/blog" class="nav-link active">Journal</a>
    </div>
  </nav>

  <header class="page-header">
    <div class="page-header-bg">JOURNAL</div>
    <div class="page-eyebrow">// The Outlyr Journal</div>
    <h1 class="page-title">Ideas<br>Before<br>They're Real.</h1>
    <p class="page-desc">Long-form writing on discipline, identity, building, and the process of deliberate becoming.</p>
    <div class="post-count">{posts.length.toString().padStart(3, '0')} Entries</div>
  </header>

  <main>
    {posts.length === 0 ? (
      <div class="posts-grid">
        <div class="empty">
          <p>Nothing here yet. The first entry is being written.</p>
        </div>
      </div>
    ) : (
      <div class="posts-grid">
        {posts.map((post, index) => (
          <a href={`/blog/${post.id}/`} class="post-card reveal">
            <div class="post-image">
              {post.data.heroImage
                ? <img src={post.data.heroImage} alt={post.data.title} />
                : <div class="post-image-placeholder"><span>OUTLYR</span></div>
              }
            </div>
            <div class="post-body">
              <div class="post-number">{(index + 1).toString().padStart(2, '0')}</div>
              <div class="post-meta">{formatDate(post.data.pubDate)}</div>
              <h2 class="post-title">{post.data.title}</h2>
              {post.data.description && (
                <p class="post-excerpt">{post.data.description}</p>
              )}
              <span class="post-link">Read entry</span>
            </div>
          </a>
        ))}
      </div>
    )}
  </main>

  <footer>
    <a href="/" class="footer-logo">OUTLYR</a>
    <div class="footer-copy">© 2025 Outlyr. All rights reserved.</div>
    <div class="footer-links">
      <a href="#">Instagram</a>
      <a href="#">X</a>
      <a href="/">Home</a>
    </div>
  </footer>

  <script>
    const navbar = document.getElementById('navbar');
    window.addEventListener('scroll', () => {
      navbar?.classList.toggle('scrolled', window.scrollY > 40);
    });

    const revealEls = document.querySelectorAll('.reveal');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry, i) => {
        if (entry.isIntersecting) {
          setTimeout(() => entry.target.classList.add('visible'), i * 100);
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.08 });
    revealEls.forEach(el => observer.observe(el));
  </script>
</body>
</html>