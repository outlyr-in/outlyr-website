---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;

function formatDate(date: Date) {
  return new Intl.DateTimeFormat('en-IN', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  }).format(date);
}
---

<BaseLayout title={`${title} — OUTLYR Journal`} activeNav="journal">
  <article class="post-page">
    <div class="container">

      <a href="/journal" class="post-back">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none"
          stroke="currentColor" stroke-width="1.5">
          <path d="M9 2L4 7l5 5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
        Back to journal
      </a>

      {heroImage && (
        <div class="post-hero">
          <img src={heroImage} alt={title} />
          <div class="post-hero-overlay" />
        </div>
      )}

      <header class="post-header">
        <div class="post-meta">
          <span>{formatDate(pubDate)}</span>
          {updatedDate && (
            <>
              <span class="post-meta-sep" />
              <span class="post-meta-updated">Updated {formatDate(updatedDate)}</span>
            </>
          )}
        </div>
        <h1 class="post-title">{title}</h1>
        {description && <p class="post-desc">{description}</p>}
      </header>

      <div class="post-body">
        <div class="prose">
          <slot />
        </div>

        <div class="post-cta">
          <p>
            Enjoyed this? Follow the build on Instagram — drops, decisions,
            behind-the-scenes, and the thinking that goes into OUTLYR.
          </p>
          <div class="post-cta-actions">
            <a href="https://instagram.com/outlyrlabs" class="btn-instagram" target="_blank" rel="noopener">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
              </svg>
              Follow on Instagram
            </a>
          </div>
        </div>
      </div>

    </div>
  </article>
</BaseLayout>

<style>
  /* ── FONTS ── */
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;1,400;1,500&family=DM+Sans:wght@300;400;500&family=DM+Mono:wght@400&display=swap');

  /* ── LAYOUT ── */
  .post-page { padding-top: 6rem; padding-bottom: 8rem; }

  .container {
    max-width: 780px;
    margin: 0 auto;
    padding: 0 32px;
  }

  /* ── BACK LINK ── */
  .post-back {
    display: inline-flex; align-items: center; gap: 0.5rem;
    font-family: 'DM Mono', monospace;
    font-size: 9px; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--t30); text-decoration: none;
    transition: color 0.3s;
    margin-bottom: 3rem;
  }
  .post-back:hover { color: var(--acc); }

  /* ── HERO ── */
  .post-hero {
    position: relative;
    width: 100%; height: 420px;
    overflow: hidden;
    margin-bottom: 3rem;
  }
  .post-hero img {
    width: 100%; height: 100%; object-fit: cover;
    filter: grayscale(15%) brightness(0.7);
  }
  .post-hero-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to bottom, transparent 40%, var(--bg) 100%);
  }

  /* ── HEADER ── */
  .post-header { margin-bottom: 3rem;}

  .post-meta {
    display: flex; align-items: center; gap: 1rem;
    font-family: 'DM Mono', monospace;
    font-size: 9px; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--acc);
    margin-bottom: 1.25rem;
  }
  .post-meta-sep {
    display: inline-block;
    width: 3px; height: 3px;
    border-radius: 50%;
    background: var(--t30);
  }
  .post-meta-updated { color: var(--t30); font-style: italic; }

  .post-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(3rem, 7vw, 6rem);
    line-height: 0.92; letter-spacing: 0.01em;
    color: var(--tx);
    margin-bottom: 1.25rem;
  }

  .post-desc {
    font-size: clamp(18px, 1.7vw, 22px);
    font-weight: 300; font-style: italic;
    line-height: 1.65; color: var(--t55);
    padding-bottom: 2.5rem;
    border-bottom: 1px solid var(--a10);
    margin: 0;
  }

  /* ── BODY ── */
  .post-body { max-width: 100%; margin: 0 auto;}

  /* ── PROSE ── */
  .prose {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: clamp(17px, 1.55vw, 20px);
    font-weight: 300; line-height: 1.9;
    color: var(--t80);
    padding: 3rem 0;
  }
  .prose p { margin-bottom: 1.75em; }
  .prose h2 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    font-weight: 500; letter-spacing: -0.02em;
    color: var(--tx); margin: 2.5em 0 1em; line-height: 1.15;
  }
  .prose h3 {
    font-family: 'DM Mono', monospace;
    font-size: 9px; letter-spacing: 0.3em; text-transform: uppercase;
    color: var(--acc); margin: 2.5em 0 1em;
  }
  .prose strong { font-weight: 500; color: var(--tx); }
  .prose em {
    font-family: 'Playfair Display', Georgia, serif;
    font-style: italic; color: rgba(237,232,225,0.9);
  }
  .prose a {
    color: var(--acc); text-decoration: none;
    border-bottom: 1px solid var(--a20); transition: border-color 0.3s;
  }
  .prose a:hover { border-bottom-color: var(--acc); }
  .prose blockquote {
    margin: 2.5em 0; padding: 2rem 2.5rem;
    border-left: 2px solid var(--acc);
    background: var(--a05);
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(18px, 1.6vw, 22px);
    font-style: italic; color: var(--t80); line-height: 1.7;
  }
  .prose ul, .prose ol { margin: 1.5em 0; padding-left: 1.5em; }
  .prose li { margin-bottom: 0.75em; }
  .prose hr { border: none; border-top: 1px solid var(--a10); margin: 3em 0; }
  .prose img { width: 100%; margin: 2.5em 0; filter: grayscale(10%) brightness(0.85); }
  .prose code {
    font-family: 'DM Mono', monospace;
    font-size: 0.8em; background: var(--a05);
    color: var(--acc); padding: 0.2em 0.5em;
  }
  .prose pre {
    background: var(--a05); border: 1px solid var(--a10);
    padding: 1.5em; overflow-x: auto; margin: 2em 0;
  }
  .prose pre code { background: transparent; padding: 0; font-size: 0.85em; line-height: 1.7; }

  /* ── CTA ── */
  .post-cta {
    padding: 2.5rem 0 0;
    border-top: 1px solid var(--a10);
  }
  .post-cta p {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 15px;
    font-weight: 300; line-height: 1.7;
    color: var(--t55);
    margin-bottom: 1.5rem;
  }
  .post-cta-actions { display: flex; gap: 1rem; flex-wrap: wrap; }

  .btn-instagram {
    display: inline-flex; align-items: center; gap: 0.5rem;
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 13px; font-weight: 500; letter-spacing: 0.05em;
    color: var(--bg);
    background: var(--acc);
    padding: 0.75rem 1.5rem;
    text-decoration: none;
    transition: opacity 0.2s, transform 0.2s;
  }
  .btn-instagram:hover { opacity: 0.85; transform: translateY(-1px); }

  /* ── RESPONSIVE ── */
  @media (max-width: 768px) {
    .container { padding: 0 20px; }
    .post-page { padding-top: 4rem; }
    .post-hero { height: 260px; }
    .post-body { max-width: 100%; }
  }
</style>