---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<BaseLayout title={`${title} — OUTLYR Journal`} activeNav="journal">

  <div class={heroImage ? 'post-wrap has-hero' : 'post-wrap'}>
    {heroImage ? (
      <div class="post-hero">
        <img src={heroImage} alt={title} />
        <div class="post-hero-overlay"></div>
      </div>
    ) : (
      <div class="post-hero-none"></div>
    )}

    <header class="post-header">
      <div class="post-eyebrow">
        <a href="/journal" class="post-back">Journal</a>
        <span class="post-date">{formatDate(pubDate)}</span>
        {updatedDate && (
          <span class="post-updated">Updated {formatDate(updatedDate)}</span>
        )}
      </div>
      <h1 class="post-title">{title}</h1>
      {description && <p class="post-description">{description}</p>}
    </header>
  </div>

  <article class="prose">
    <slot />
  </article>

  <div class="post-footer">
    <a href="/journal" class="back-to-journal">Back to Journal</a>
    <div class="post-footer-logo">OUTLYR</div>
  </div>

</BaseLayout>

<style>
  /* ── HERO IMAGE ── */
  .post-hero {
    width: 100%;
    height: 60vh; min-height: 400px; max-height: 680px;
    overflow: hidden; position: relative;
  }
  .post-hero img {
    width: 100%; height: 100%; object-fit: cover; display: block;
    filter: grayscale(15%) brightness(0.7);
  }
  .post-hero-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to bottom, transparent 40%, var(--bg) 100%);
  }
  .post-hero-none {
    width: 100%;
    padding-top: 8rem;
    border-bottom: 1px solid var(--a10);
  }

  /* ── POST HEADER ── */
  .post-header {
    max-width: 780px;
    margin: 0 auto;
    padding: 4rem 56px 3rem;
  }
  .has-hero .post-header {
    padding-top: 0;
    position: relative; z-index: 2;
    margin-top: -12rem;
  }
  .post-eyebrow {
    display: flex; align-items: center;
    gap: 2rem; margin-bottom: 2rem;
  }
  .post-back {
    font-family: 'DM Mono', monospace;
    font-size: 9px; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--t30); text-decoration: none;
    transition: color 0.3s;
    display: flex; align-items: center; gap: 0.5rem;
  }
  .post-back::before { content: '←'; }
  .post-back:hover { color: var(--acc); }

  .post-date {
    font-family: 'DM Mono', monospace;
    font-size: 9px; letter-spacing: 0.2em;
    color: var(--acc); text-transform: uppercase;
  }
  .post-updated {
    font-family: 'DM Mono', monospace;
    font-size: 9px; letter-spacing: 0.15em;
    color: var(--t30); text-transform: uppercase; font-style: italic;
  }
  .post-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(3rem, 7vw, 6.5rem);
    line-height: 0.9; letter-spacing: 0.01em;
    color: var(--tx); margin-bottom: 1.5rem;
  }
  .post-description {
    font-size: clamp(20px, 1.8vw, 24px);
    font-weight: 300; font-style: italic;
    line-height: 1.65; color: var(--t55);
    margin-bottom: 3rem; padding-bottom: 3rem;
    border-bottom: 1px solid var(--a10);
  }

  /* ── PROSE ── */
  .prose {
    max-width: 680px;
    margin: 0 auto;
    padding: 0 56px 6rem;
    font-size: clamp(18px, 1.6vw, 22px);
    font-weight: 300; line-height: 1.9;
    color: var(--t80);
  }
  .prose p { margin-bottom: 1.75em; }
  .prose h2 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 2.5rem; letter-spacing: 0.05em;
    color: var(--tx); margin: 2.5em 0 1em; line-height: 1;
  }
  .prose h3 {
    font-family: 'DM Mono', monospace;
    font-size: 9px; letter-spacing: 0.3em; text-transform: uppercase;
    color: var(--acc); margin: 2.5em 0 1em;
  }
  .prose strong { font-weight: 400; color: var(--tx); }
  .prose em { font-style: italic; color: rgba(237,232,225,0.9); }
  .prose a {
    color: var(--acc); text-decoration: none;
    border-bottom: 1px solid var(--a20);
    transition: border-color 0.3s;
  }
  .prose a:hover { border-bottom-color: var(--acc); }
  .prose blockquote {
    margin: 2.5em 0; padding: 2rem 2.5rem;
    border-left: 2px solid var(--acc);
    background: var(--a05);
    font-size: clamp(20px, 1.8vw, 24px);
    font-style: italic; color: var(--t80); line-height: 1.7;
  }
  .prose ul, .prose ol { margin: 1.5em 0; padding-left: 1.5em; }
  .prose li { margin-bottom: 0.75em; }
  .prose hr { border: none; border-top: 1px solid var(--a10); margin: 3em 0; }
  .prose img {
    width: 100%; margin: 2.5em 0;
    filter: grayscale(10%) brightness(0.85);
  }
  .prose code {
    font-family: 'DM Mono', monospace;
    font-size: 0.8em; background: var(--a05);
    color: var(--acc); padding: 0.2em 0.5em;
  }
  .prose pre {
    background: var(--a05); border: 1px solid var(--a10);
    padding: 1.5em; overflow-x: auto; margin: 2em 0;
  }
  .prose pre code { background: transparent; padding: 0; font-size: 0.85em; line-height: 1.7; }

  /* ── POST FOOTER ── */
  .post-footer {
    max-width: 680px; margin: 0 auto;
    padding: 3rem 56px 6rem;
    border-top: 1px solid var(--a10);
    display: flex; justify-content: space-between; align-items: center;
  }
  .back-to-journal {
    display: inline-flex; align-items: center; gap: 0.75rem;
    font-family: 'DM Mono', monospace;
    font-size: 9px; letter-spacing: 0.3em; text-transform: uppercase;
    color: var(--acc); text-decoration: none;
    transition: gap 0.3s ease;
  }
  .back-to-journal::before { content: '←'; }
  .back-to-journal:hover { gap: 1.2rem; }
  .post-footer-logo {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.2rem; letter-spacing: 0.35em;
    color: var(--a20);
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 768px) {
    .post-hero { height: 40vh; min-height: 260px; }
    .post-header, .prose, .post-footer { padding-left: 24px; padding-right: 24px; }
    .has-hero .post-header { margin-top: -8rem; }
  }
</style>