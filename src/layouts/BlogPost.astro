---
import type { CollectionEntry } from 'astro:content';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>{title} — OUTLYR Journal</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --black: #0a0a08;
      --off-white: #f0ede6;
      --gold: #c8a96e;
      --gold-dim: #8a6e3e;
      --muted: #3a3830;
    }

    html { scroll-behavior: smooth; }

    body {
      background-color: var(--black);
      color: var(--off-white);
      font-family: 'Cormorant Garamond', serif;
      overflow-x: hidden;
      cursor: crosshair;
      min-height: 100vh;
    }

    body::before {
      content: '';
      position: fixed; inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='1'/%3E%3C/svg%3E");
      opacity: 0.045;
      pointer-events: none;
      z-index: 9999;
    }

    /* ── NAV ── */
    nav {
      position: fixed; top: 0; left: 0; right: 0;
      display: flex; justify-content: space-between; align-items: center;
      padding: 2rem 3rem;
      z-index: 100;
      transition: background 0.4s ease, padding 0.4s ease, border-color 0.4s ease;
      border-bottom: 1px solid transparent;
    }
    nav.scrolled {
      background: rgba(10, 10, 8, 0.75);
      backdrop-filter: blur(18px);
      -webkit-backdrop-filter: blur(18px);
      padding: 1.2rem 3rem;
      border-bottom-color: rgba(200, 169, 110, 0.08);
    }
    .nav-logo {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.6rem;
      letter-spacing: 0.3em;
      color: var(--off-white);
      text-decoration: none;
    }
    .nav-right {
      display: flex;
      align-items: center;
      gap: 2.5rem;
    }
    .nav-link {
      font-family: 'Space Mono', monospace;
      font-size: 0.6rem;
      letter-spacing: 0.2em;
      color: rgba(240, 237, 230, 0.45);
      text-decoration: none;
      text-transform: uppercase;
      transition: color 0.3s;
    }
    .nav-link:hover { color: var(--gold); }

    /* ── HERO IMAGE ── */
    .post-hero {
      width: 100%;
      height: 60vh;
      min-height: 400px;
      max-height: 680px;
      overflow: hidden;
      position: relative;
    }
    .post-hero img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      filter: grayscale(15%) brightness(0.7);
    }
    .post-hero-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to bottom, transparent 40%, var(--black) 100%);
    }
    .post-hero-none {
      width: 100%;
      padding-top: 8rem;
      border-bottom: 1px solid rgba(200, 169, 110, 0.1);
    }

    /* ── POST HEADER ── */
    .post-header {
      max-width: 780px;
      margin: 0 auto;
      padding: 4rem 3rem 3rem;
    }
    .has-hero .post-header {
      padding-top: 0;
      position: relative;
      z-index: 2;
      margin-top: -12rem;
    }
    .post-eyebrow {
      display: flex;
      align-items: center;
      gap: 2rem;
      margin-bottom: 2rem;
    }
    .post-back {
      font-family: 'Space Mono', monospace;
      font-size: 0.58rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(240, 237, 230, 0.35);
      text-decoration: none;
      transition: color 0.3s;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .post-back::before { content: '←'; }
    .post-back:hover { color: var(--gold); }
    .post-date {
      font-family: 'Space Mono', monospace;
      font-size: 0.58rem;
      letter-spacing: 0.2em;
      color: var(--gold);
      text-transform: uppercase;
    }
    .post-updated {
      font-family: 'Space Mono', monospace;
      font-size: 0.55rem;
      letter-spacing: 0.15em;
      color: var(--muted);
      text-transform: uppercase;
      font-style: italic;
    }
    .post-title {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(3rem, 7vw, 6.5rem);
      line-height: 0.9;
      letter-spacing: 0.01em;
      color: var(--off-white);
      margin-bottom: 1.5rem;
    }
    .post-description {
      font-size: 1.3rem;
      font-weight: 300;
      font-style: italic;
      line-height: 1.65;
      color: rgba(240, 237, 230, 0.55);
      margin-bottom: 3rem;
      padding-bottom: 3rem;
      border-bottom: 1px solid rgba(200, 169, 110, 0.15);
    }

    /* ── PROSE ── */
    .prose {
      max-width: 680px;
      margin: 0 auto;
      padding: 0 3rem 6rem;
      font-size: 1.2rem;
      font-weight: 300;
      line-height: 1.9;
      color: rgba(240, 237, 230, 0.75);
    }

    .prose p { margin-bottom: 1.75em; }

    .prose h2 {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 2.5rem;
      letter-spacing: 0.05em;
      color: var(--off-white);
      margin: 2.5em 0 1em;
      line-height: 1;
    }

    .prose h3 {
      font-family: 'Space Mono', monospace;
      font-size: 0.75rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--gold);
      margin: 2.5em 0 1em;
    }

    .prose strong {
      font-weight: 400;
      color: var(--off-white);
    }

    .prose em {
      font-style: italic;
      color: rgba(240, 237, 230, 0.9);
    }

    .prose a {
      color: var(--gold);
      text-decoration: none;
      border-bottom: 1px solid rgba(200, 169, 110, 0.3);
      transition: border-color 0.3s;
    }
    .prose a:hover { border-bottom-color: var(--gold); }

    .prose blockquote {
      margin: 2.5em 0;
      padding: 2rem 2.5rem;
      border-left: 2px solid var(--gold);
      background: rgba(200, 169, 110, 0.04);
      font-size: 1.3rem;
      font-style: italic;
      color: rgba(240, 237, 230, 0.8);
      line-height: 1.7;
    }

    .prose ul, .prose ol {
      margin: 1.5em 0;
      padding-left: 1.5em;
    }
    .prose li { margin-bottom: 0.75em; }

    .prose hr {
      border: none;
      border-top: 1px solid rgba(200, 169, 110, 0.15);
      margin: 3em 0;
    }

    .prose img {
      width: 100%;
      border-radius: 4px;
      margin: 2.5em 0;
      filter: grayscale(10%) brightness(0.85);
    }

    .prose code {
      font-family: 'Space Mono', monospace;
      font-size: 0.8em;
      background: rgba(200, 169, 110, 0.08);
      color: var(--gold);
      padding: 0.2em 0.5em;
      border-radius: 3px;
    }

    .prose pre {
      background: rgba(200, 169, 110, 0.05);
      border: 1px solid rgba(200, 169, 110, 0.1);
      border-radius: 4px;
      padding: 1.5em;
      overflow-x: auto;
      margin: 2em 0;
    }
    .prose pre code {
      background: transparent;
      padding: 0;
      font-size: 0.85em;
      line-height: 1.7;
    }

    /* ── POST FOOTER ── */
    .post-footer {
      max-width: 680px;
      margin: 0 auto;
      padding: 0 3rem 6rem;
      border-top: 1px solid rgba(200, 169, 110, 0.1);
      padding-top: 3rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .back-to-journal {
      display: inline-flex;
      align-items: center;
      gap: 0.75rem;
      font-family: 'Space Mono', monospace;
      font-size: 0.6rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--gold);
      text-decoration: none;
      transition: gap 0.3s ease;
    }
    .back-to-journal::before { content: '←'; }
    .back-to-journal:hover { gap: 1.2rem; }
    .post-footer-logo {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.2rem;
      letter-spacing: 0.35em;
      color: rgba(240, 237, 230, 0.15);
    }

    /* ── SITE FOOTER ── */
    footer {
      padding: 3rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-top: 1px solid rgba(240, 237, 230, 0.05);
    }
    .footer-logo {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.2rem;
      letter-spacing: 0.35em;
      color: rgba(240, 237, 230, 0.25);
      text-decoration: none;
    }
    .footer-copy {
      font-family: 'Space Mono', monospace;
      font-size: 0.55rem;
      letter-spacing: 0.2em;
      color: rgba(240, 237, 230, 0.2);
    }
    .footer-links {
      display: flex;
      gap: 2rem;
    }
    .footer-links a {
      font-family: 'Space Mono', monospace;
      font-size: 0.6rem;
      letter-spacing: 0.2em;
      color: rgba(240, 237, 230, 0.3);
      text-decoration: none;
      text-transform: uppercase;
      transition: color 0.3s;
    }
    .footer-links a:hover { color: var(--gold); }

    /* ── RESPONSIVE ── */
    @media (max-width: 768px) {
      nav { padding: 1.5rem; }
      nav.scrolled { padding: 1rem 1.5rem; }
      .post-hero { height: 40vh; min-height: 260px; }
      .post-header, .prose, .post-footer { padding-left: 1.5rem; padding-right: 1.5rem; }
      .has-hero .post-header { margin-top: -8rem; }
      footer { flex-direction: column; gap: 1.5rem; text-align: center; padding: 2rem 1.5rem; }
      .footer-links { justify-content: center; }
    }
  </style>
</head>
<body>

  <nav id="navbar">
    <a href="/" class="nav-logo">OUTLYR</a>
    <div class="nav-right">
      <a href="/" class="nav-link">Home</a>
      <a href="/blog" class="nav-link">Journal</a>
    </div>
  </nav>

  <div class={heroImage ? 'has-hero' : ''}>
    {heroImage
      ? (
        <div class="post-hero">
          <img src={heroImage} alt={title} />
          <div class="post-hero-overlay"></div>
        </div>
      )
      : <div class="post-hero-none"></div>
    }

    <header class="post-header">
      <div class="post-eyebrow">
        <a href="/blog" class="post-back">Journal</a>
        <span class="post-date">{formatDate(pubDate)}</span>
        {updatedDate && (
          <span class="post-updated">Updated {formatDate(updatedDate)}</span>
        )}
      </div>
      <h1 class="post-title">{title}</h1>
      {description && <p class="post-description">{description}</p>}
    </header>
  </div>

  <article class="prose">
    <slot />
  </article>

  <div class="post-footer">
    <a href="/blog" class="back-to-journal">Back to Journal</a>
    <div class="post-footer-logo">OUTLYR</div>
  </div>

  <footer>
    <a href="/" class="footer-logo">OUTLYR</a>
    <div class="footer-copy">© 2025 Outlyr. All rights reserved.</div>
    <div class="footer-links">
      <a href="#">Instagram</a>
      <a href="#">X</a>
      <a href="/">Home</a>
    </div>
  </footer>

  <script>
    const navbar = document.getElementById('navbar');
    window.addEventListener('scroll', () => {
      navbar?.classList.toggle('scrolled', window.scrollY > 40);
    });
  </script>
</body>
</html>